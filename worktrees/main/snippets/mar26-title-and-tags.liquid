{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
MAR26 TITLE AND TAGS (Unified Block)
VERSION: 1.4.1 - Montserrat alignment and padding refinement for high-density UI.
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}

<style>
  #block-{{ block.id }}.mar26-title-and-tags-block {
    margin: 0;
  }

  #block-{{ block.id }} .mar26-title-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    margin: 0 0 10px !important; /* DESKTOP MARGIN: Gap between tags and title */
  }

  #block-{{ block.id }} .mar26-title-tags__tag {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 999px;
    /* tag background & text color removed from here since they are dynamic now */
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.1), 0 3px 8px rgba(15, 23, 42, 0.04);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    line-height: normal;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  #block-{{ block.id }} .mar26-title-tags__heading {
    margin: 0;
    line-height: 1.05;
    font-family: 'Montserrat', sans-serif;
  }

  @media screen and (max-width: 999px) {
    #block-{{ block.id }} .mar26-title-tags {
      gap: 0.3125rem;
      margin-bottom: 10px !important; /* MOBILE MARGIN: Gap between tags and title */
    }

    #block-{{ block.id }} .mar26-title-tags__tag {
      min-height: 1.5rem;
      padding: 0.18rem 0.5rem;
      font-size: 0.68rem;
    }
  }
</style>

<div id="block-{{ block.id }}" class="mar26-title-and-tags-block">
{%- assign color_tags = product.metafields.custom.color_tags.value -%}
{%- if color_tags != blank -%}
  <div class="mar26-title-tags" aria-label="Product tags">
    {%- for tag_obj in color_tags -%}
      {%- assign bg_color = tag_obj.color.value | default: tag_obj.tag_color.value | default: '#000000' -%}
      {%- assign text_val = tag_obj.name.value | default: tag_obj.tag_name.value | strip -%}
      {%- if text_val != blank -%}
        <span class="mar26-title-tags__tag" style="background: {{ bg_color }}; color: #ffffff;">{{ text_val | escape }}</span>
      {%- endif -%}
    {%- endfor -%}
  </div>
{%- endif -%}

<{{ heading_tag }} class="product-info__title mar26-title-tags__heading {{ heading_tag }}">
  {{- product.title -}}
</{{ heading_tag }}>
</div>