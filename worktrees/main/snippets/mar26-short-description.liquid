{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
file-summary: MAR26 short description card. Renders the compact description and three highlight bullets.
version-name: Density Pass for 80%-Zoom Look
version-number: 0.0.8
version-date: 2026-03-31
version-summary: Reduces padding, radius, shadow, text/icon size, and list gap for denser appearance.
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign h1 = block.settings.highlight_1 -%}
{%- assign h2 = block.settings.highlight_2 -%}
{%- assign h3 = block.settings.highlight_3 -%}

{%- if h1 != blank or h2 != blank or h3 != blank -%}
  <style>
    .mar26-short-description-wrapper {
      width: 100%;
      max-width: 100%;
      margin: 0;
    }
    .mar26-short-description-stack {
      width: 100%;
      max-width: 100%;
    }
    .mar26-short-description-card {
      background-color: #fff;
      border: none;
      border-radius: 0.625rem !important;
      padding: 8px;
      margin-top: 14px;
      box-shadow: none;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
      overflow-wrap: anywhere;
      margin-left: auto;
      margin-right: auto;
    }
    .mar26-short-description-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
      width: 100%;
    }
    .mar26-short-description-text {
      font-size: 12px;
      color: #1e293b;
      line-height: 1.45;
      margin-bottom: 8px;
      text-align: left;
      width: 100%;
    }
    .mar26-short-description-item {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      font-size: 12px;
      font-weight: 500;
      color: #334155;
      line-height: 1.35;
      text-align: left;
      width: 100%;
      min-width: 0;
    }
    .mar26-short-description-item-text {
      flex: 1 1 auto;
      min-width: 0;
      white-space: normal;
      overflow-wrap: anywhere;
    }
    .mar26-short-description-icon {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
      background-color: {{ block.settings.icon_color | default: '#e11d48' | color_modify: 'alpha', 0.1 }};
      color: {{ block.settings.icon_color | default: '#e11d48' }};
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .mar26-short-description-icon svg {
      width: 8px;
      height: 8px;
      stroke-width: 3;
    }

    @media screen and (max-width: 999px) {
      .mar26-short-description-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .mar26-short-description-stack {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        width: min(100%, 32rem);
        margin-left: auto;
        margin-right: auto;
      }

      .mar26-short-description-card {
        width: 100%;
        max-width: 100%;
        margin-left: 0;
        margin-right: 0;
        box-sizing: border-box;
        border-radius: 0.625rem !important;
      }
    }
  </style>

  {%- assign description = product.metafields.custom.mar_26_highlights_description.value | default: block.settings.description -%}

  <div class="mar26-short-description-wrapper">
    <div class="mar26-short-description-stack">
      <div class="mar26-short-description-card">
        {%- if description != blank -%}
          <div class="mar26-short-description-text">
            {{- description -}}
          </div>
        {%- endif -%}
        <ul class="mar26-short-description-list">
          {%- if h1 != blank -%}
            <li class="mar26-short-description-item">
              <div class="mar26-short-description-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <span class="mar26-short-description-item-text">{{ h1 }}</span>
            </li>
          {%- endif -%}
          {%- if h2 != blank -%}
            <li class="mar26-short-description-item">
              <div class="mar26-short-description-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <span class="mar26-short-description-item-text">{{ h2 }}</span>
            </li>
          {%- endif -%}
          {%- if h3 != blank -%}
            <li class="mar26-short-description-item">
              <div class="mar26-short-description-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <span class="mar26-short-description-item-text">{{ h3 }}</span>
            </li>
          {%- endif -%}
        </ul>
      </div>
    </div>
  </div>
{%- endif -%}
