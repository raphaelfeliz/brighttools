    "faq": {
      "type": "faq",
      "blocks": {
        "faq_1": {
          "type": "item",
          "settings": {
            "title": "Is the Glider S-1 safe for high-rise windows?",
            "content": "<p>Yes. Only open your window enough to place the outer half through. The included safety string keeps the Glider attached at all times. The magnets are strong enough to hold firm even in wind.</p>"
          }
        },
        "faq_2": {
          "type": "item",
          "settings": {
            "title": "How do I clean the outside if I can't reach it?",
            "content": "<p>Spray cleaning solution along the window edge nearest to you. As you glide the S-1, the blades spread the solution across the entire surface. You can also pre-wet the microfibre cloths before attaching them.</p>"
          }
        },
        "faq_3": {
          "type": "item",
          "settings": {
            "title": "What window thickness does the S-1 support?",
            "content": "<p>Single-glazed windows from 2mm to 8mm thick. If you're unsure of your window thickness, check our measurement guide for step-by-step instructions.</p>"
          }
        },
        "faq_4": {
          "type": "item",
          "settings": {
            "title": "How long do the microfibre cloths last?",
            "content": "<p>Each cloth can be washed and reused up to 300 times with zero loss in cleaning performance.</p>"
          }
        },
        "faq_5": {
          "type": "item",
          "settings": {
            "title": "Is this the genuine Glider?",
            "content": "<p>Yes. This is the original Glider by Tyroler Bright Tools with a 2-year warranty and 30-day money-back guarantee. Beware of low-quality imitation products which look the same but use inferior magnets and materials.</p>"
          }
        }
      },
