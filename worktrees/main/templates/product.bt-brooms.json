        "liquid": "<style>\n  .scroll-to-top {\n    position: fixed;\n    bottom: 20px;\n    right: 20px;\n    background-color: #000;\n    color: #fff;\n    border: none;\n    border-radius: 8px;\n    padding: 12px 16px;\n    font-size: 14px;\n    cursor: pointer;\n    display: none;\n    z-index: 9999; /* Increased to stay above Shopify layers */\n    font-weight: 600;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    white-space: nowrap;\n  }\n  .scroll-to-top.show {\n    display: flex;\n  }\n  .scroll-to-top:hover {\n    background-color: #333;\n  }\n</style>\n\n<button class=\"scroll-to-top\" id=\"scrollToTopBtn\"><span>↑</span><span>shop</span></button>\n\n<script>\n  (function() {\n    const btn = document.getElementById('scrollToTopBtn');\n\n    window.addEventListener('scroll', function() {\n      if (window.pageYOffset > 300) {\n        btn.classList.add('show');\n      } else {\n        btn.classList.remove('show');\n      }\n    });\n\n    btn.addEventListener('click', function() {\n      // We look for the element INSIDE the click function \n      // so it finds it even if the page loaded slowly.\n      const target = document.querySelector('product-info.mar26-addons-buy');\n\n      if (target) {\n        // Calculate header height from your CSS variables (--header-height: 120px)\n        const headerOffset = 130; \n        const elementPosition = target.getBoundingClientRect().top;\n        const offsetPosition = elementPosition + window.pageYOffset - headerOffset;\n\n        window.scrollTo({\n          top: offsetPosition,\n          behavior: 'smooth'\n        });\n      } else {\n        // If the specific class isn't found, try finding ANY product-info\n        const backupTarget = document.querySelector('product-info');\n        if (backupTarget) {\n           backupTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });\n        } else {\n           window.scrollTo({ top: 0, behavior: 'smooth' });\n        }\n      }\n    });\n  })();\n</script>",
