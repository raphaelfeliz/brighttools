        "heading_PU96mb": {
          "type": "heading",
          "settings": {
            "text": "Easy Magnetic Window Cleaning Tips",
            "heading_tag": "h2",
            "text_color": "",
            "gradient": ""
          }
        },
        "richtext_34RhiL": {
          "type": "richtext",
          "settings": {
            "content": "<ul><li>Choose a <strong>magnetic window cleaner</strong> made from strong materials like <strong>100% Rubber</strong> for double-sided action, high quality and performance.</li><li>Select the right glider model for your window thickness from 2mm-40mm for single, double or triple glazed windows.</li><li>Invest in a high window cleaning solution with a 2-in-1 high window washer, <strong>extendable handle</strong> and flexible head to get up high while staying grounded.</li><li>Use cleaning liquid at the edge of your windows, the brilliant blades will push the solution along for you.</li><li>Let the magnets do the work. Safely and easily glide across your windows for extreme comfort and a streak-free clean.</li><li>Get to all those hard to reach places with minimum effort and clear as day shine.</li></ul>"
          }
        }
      },
      "block_order": [
