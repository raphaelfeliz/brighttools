    "d9e91537-6225-4b57-bd84-e5d10e8558b3": {
      "type": "faq",
      "blocks": {
        "template--19202935587090__d9e91537-6225-4b57-bd84-e5d10e8558b3-1686662624baccc985-0": {
          "type": "item",
          "settings": {
            "title": "Are BrightTools products suitable for both professionals and amateurs?",
            "content": "<p>Absolutely! Our tools are designed to cater to the needs of professionals as well as hobbyists and DIY enthusiasts. We strive to offer products that are user-friendly, reliable, and suitable for various skill levels.</p>"
          }
        },
        "template--19202935587090__d9e91537-6225-4b57-bd84-e5d10e8558b3-1686662624baccc985-1": {
          "type": "item",
          "settings": {
            "title": "Can I track the status of my order?",
            "content": "<p>Yes, once your order is confirmed, we will provide you with a tracking number. You can use this number to track the status of your shipment. We also send regular updates via email, keeping you informed about the progress of your order.</p>"
          }
        },
        "template--19202935587090__d9e91537-6225-4b57-bd84-e5d10e8558b3-1686662624baccc985-2": {
          "type": "item",
          "settings": {
            "title": "What payment options are available?",
            "content": "<p>We accept various payment methods, including major credit cards (Visa, Mastercard, American Express), PayPal, and bank transfers. Rest assured that all transactions are securely processed to protect your sensitive information.</p>"
          }
        },
        "dc709b98-8f74-4f10-9911-a3d0da4bdcf4": {
          "type": "item",
          "settings": {
            "title": "Do you offer international shipping?",
            "content": "<p>Yes, we offer international shipping to select countries. However, please note that shipping fees and delivery times may vary depending on the destination. During the checkout process, you can enter your location to view the available shipping options and associated costs.</p>"
          }
        }
      },
