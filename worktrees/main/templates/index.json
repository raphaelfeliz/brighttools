        "testimonial_dARCyM": {
          "type": "testimonial",
          "settings": {
            "author": "Sonia",
            "country": "australia",
            "content": "<p>The floor wipes leave my home smelling so fresh. I have a dog and I use these every night once he goes to bed to freshen his play area.</p>",
