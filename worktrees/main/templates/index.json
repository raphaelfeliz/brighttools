        "testimonial_63cUpE": {
          "type": "testimonial",
          "settings": {
            "author": "Evelyn M.",
            "country": "australia",
            "content": "<p>This Wipes have been brilliant for me as I’ve got sciatica and using this floor mop has done a great job of cleaning the house without too much effort.</p>",
