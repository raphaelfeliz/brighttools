    "beeafe09-2cb1-4ed4-9a41-c04f9f65c5d4": {
      "type": "faq",
      "blocks": {
        "template--19202935849234__beeafe09-2cb1-4ed4-9a41-c04f9f65c5d4-168657506649ab31c8-0": {
          "type": "item",
          "settings": {
            "title": "Are Bright Tools products suitable for both professionals and amateurs?",
            "content": "<p>Absolutely! Our tools are designed to cater to the needs of professionals as well as hobbyists and DIY enthusiasts. We strive to offer products that are user-friendly, reliable, and suitable for various skill levels.</p>"
          }
        },
        "template--19202935849234__beeafe09-2cb1-4ed4-9a41-c04f9f65c5d4-168657506649ab31c8-1": {
          "type": "item",
          "settings": {
            "title": "How quickly do you dispatch orders within Australia, and what shipping options do you offer?",
            "content": "<p>We dispatch all orders Australia-wide within 24 hours, so your cleaning tools will arrive at your door without delay. Our products are sent via trackable Australia Post and with express options available you can feel secure in our fast shipping delivery. </p>"
          }
        },
        "fc47d9e3-e809-41ad-a3a4-afa79b9bd8ba": {
          "type": "item",
          "settings": {
            "title": "Is it possible to receive a full refund or exchange for a product if I am not satisfied with my purchase?",
            "content": "<p>We’re here to make your life easier. If you’re not fully satisfied with any Bright Tools product we offer a full refund or exchange with proof of purchase within 30 days. We’re so confident in our range and giving you the best cleaning experience at home, if you’re not floored, then we make returns easy. </p>"
          }
        },
        "e478ad9a-f406-475f-be47-70bbcc894202": {
          "type": "item",
          "settings": {
            "title": "What is the warranty duration for Bright Tools' household cleaning products, and what sets your warranty and product longevity apart from other cleaning brands in Australia?",
            "content": "<p>Bright Tools offer a unique 2 year warranty on all of our household cleaning products. We stand behind the quality and durability of our superior tools and our sustainable silicone. Unlike any other cleaning brand in Australia, you’ll get guaranteed longevity with every product purchase. </p>"
          }
        },
        "template--19202935849234__beeafe09-2cb1-4ed4-9a41-c04f9f65c5d4-168657506649ab31c8-2": {
          "type": "item",
          "settings": {
            "title": "What payment options are available?",
            "content": "<p>We accept various payment methods, including major credit cards (Visa, Mastercard, American Express), PayPal, and bank transfers. Rest assured that all transactions are securely processed to protect your sensitive information.</p>"
          }
        }
      },
