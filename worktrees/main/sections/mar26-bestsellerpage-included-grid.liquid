{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
MAR26 BESTSELLERPAGE INCLUDED GRID (Phase 2)
----------------------------------------------------------------------------------------------------------------------
High-density overview grid of bundle components with Sidekick accent cards.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --grid-accent-color: {{ section.settings.accent_color }};
  }

  .mar26-included-wrapper {
    background-color: transparent;
    padding: 30px 1.5rem;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Offset for hero overlap if needed */
  .mar26-included-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem 1.5rem;
  }

  @media (min-width: 640px) {
    .mar26-included-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .mar26-included-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .mar26-included-card {
    background-color: #ffffff;
    border-radius: 1.25rem;
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: center;
    padding-right: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    height: 100%;
    min-height: 120px;
  }

  /* The "Sidekick" left accent bar */
  .mar26-included-card::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: -6px;
    width: 20px; /* Small overlap to hide rounding gap */
    background-color: var(--card-accent, #ccc);
    border-radius: 1.25rem;
    z-index: -1;
  }

  .mar26-included-img {
    width: 110px;
    aspect-ratio: 1/1;
    background-color: #ffffff;
    padding: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border-top-left-radius: 1.25rem;
    border-bottom-left-radius: 1.25rem;
    overflow: hidden;
  }

  .mar26-included-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .mar26-included-content {
    padding: 1rem 0;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .mar26-included-title {
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    color: #000;
    margin-bottom: 0.75rem;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .mar26-included-specs {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .mar26-included-spec-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    white-space: nowrap;
  }

  .mar26-included-spec-item svg {
    width: 1rem;
    height: 1rem;
    color: #13809e; /* Default teal icon */
    flex-shrink: 0;
  }

  .mar26-included-more-btn {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translate(-50%, 50%);
    background-color: #000;
    color: #fff;
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 1rem;
    border-radius: 9999px;
    text-decoration: none;
    z-index: 30;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: all 0.2s ease;
  }

  .mar26-included-more-btn:hover {
    background-color: var(--grid-accent-color);
    transform: translate(-50%, 50%) scale(1.1);
  }
</style>

<div class="mar26-included-wrapper">
  <div class="mar26-included-grid">
    {%- for block in section.blocks -%}
      <article class="mar26-included-card" style="--card-accent: {{ block.settings.accent_color }};" {{ block.shopify_attributes }}>
        <div class="mar26-included-img">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag }}
          {%- endif -%}
        </div>

        <div class="mar26-included-content">
          <h3 class="mar26-included-title">{{ block.settings.title | escape }}</h3>
          
          <ul class="mar26-included-specs">
            {%- if block.settings.spec_1 != blank -%}
              <li class="mar26-included-spec-item">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                <span>{{ block.settings.spec_1 | escape }}</span>
              </li>
            {%- endif -%}
            {%- if block.settings.spec_2 != blank -%}
              <li class="mar26-included-spec-item">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                <span>{{ block.settings.spec_2 | escape }}</span>
              </li>
            {%- endif -%}
            {%- if block.settings.spec_3 != blank -%}
              <li class="mar26-included-spec-item">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                <span>{{ block.settings.spec_3 | escape }}</span>
              </li>
            {%- endif -%}
          </ul>
        </div>

        {%- if block.settings.anchor_id != blank -%}
          <a href="#{{ block.settings.anchor_id }}" class="mar26-included-more-btn">more</a>
        {%- endif -%}
      </article>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "MAR26 Bestseller Grid",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button Hover Color",
      "default": "#f81b27"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Sidekick Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Product Title"
        },
        {
          "type": "text",
          "id": "spec_1",
          "label": "Feature 1",
          "default": "Feature One"
        },
        {
          "type": "text",
          "id": "spec_2",
          "label": "Feature 2",
          "default": "Feature Two"
        },
        {
          "type": "text",
          "id": "spec_3",
          "label": "Feature 3",
          "default": "Feature Three"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Side Accent Color",
          "default": "#13809e"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Deep Link ID (Target section ID)",
          "info": "e.g. deep-dive-broom"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MAR26 Bestseller Included Grid",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
