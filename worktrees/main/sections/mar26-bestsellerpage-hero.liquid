{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
MAR26 BESTSELLERPAGE HERO (Phase 1)
----------------------------------------------------------------------------------------------------------------------
Premium high-impact hero section with dual-layer background and gradient typography.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --text-color: {{ section.settings.text_color }};
    --accent-color: {{ section.settings.accent_color }};
    --bg-overlay: {{ section.settings.overlay_color | color_modify: 'alpha', 0.85 }};
  }

  .mar26-hero-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    overflow: hidden;
    min-height: 500px;
    background-color: #000;
  }

  .mar26-hero-bg-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .mar26-hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: bottom;
    display: block;
  }

  .mar26-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.8) 40%, rgba(0,0,0,0) 100%);
    z-index: 2;
  }

  @media (max-width: 767px) {
    .mar26-hero-overlay {
      background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.7) 60%, rgba(0,0,0,0.2) 100%);
    }
    .mar26-hero-bg-desktop { display: none; }
    .mar26-hero-bg-mobile { display: block; }
  }
  @media (min-width: 768px) {
    .mar26-hero-bg-desktop { display: block; }
    .mar26-hero-bg-mobile { display: none; }
  }

  .mar26-hero-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    position: relative;
    z-index: 3;
    text-align: left;
  }

  @media (max-width: 767px) {
    .mar26-hero-inner {
      text-align: center;
      padding: 2rem 1.5rem 4rem;
    }
  }

  .mar26-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.2);
    background-color: rgba(0,0,0,0.4);
    color: {{ section.settings.badge_text_color }};
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }

  .mar26-hero-badge-icon {
    position: relative;
    width: 0.75rem;
    height: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mar26-hero-badge-icon svg {
    position: absolute;
    width: 2rem;
    height: 2rem;
    color: var(--accent-color);
    transform: rotate(-10deg) translateX(-4px);
  }

  .mar26-hero-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: #fff;
  }

  .mar26-hero-title-accent {
    color: var(--accent-color);
    display: block;
  }

  .mar26-hero-desc {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 500;
    line-height: 1.6;
    color: rgba(255,255,255,0.8);
    margin-bottom: 2.5rem;
    max-width: 600px;
  }

  .mar26-hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .mar26-hero-actions {
      flex-direction: row;
      justify-content: flex-start;
    }
  }

  .mar26-hero-cta {
    display: inline-block;
    background-color: var(--accent-color);
    color: #fff;
    font-weight: 900;
    text-transform: uppercase;
    padding: 1.25rem 2.5rem;
    border-radius: 0.75rem;
    font-size: 1.125rem;
    transition: all 0.3s ease;
    text-decoration: none;
    line-height: 1;
  }

  .mar26-hero-cta:hover {
    background-color: #fff;
    color: #000;
    transform: translateY(-2px);
  }

  .mar26-hero-price-stack {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .mar26-hero-price-now {
    font-size: 1.25rem;
    font-weight: 900;
    color: #fff;
  }
  
  .mar26-hero-price-now span {
    font-size: 0.75rem;
    opacity: 0.5;
    margin-left: 0.25rem;
  }

  .mar26-hero-price-was {
    font-size: 0.875rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    text-decoration: line-through;
  }
</style>

<div class="mar26-hero-wrapper">
  {%- comment -%} Background Layers {%- endcomment -%}
  <div class="mar26-hero-bg-layer">
    {%- if section.settings.image_desktop != blank -%}
      {{ section.settings.image_desktop | image_url: width: 2400 | image_tag: class: 'mar26-hero-bg-img mar26-hero-bg-desktop', loading: 'eager' }}
    {%- endif -%}
    {%- if section.settings.image_mobile != blank -%}
      {{ section.settings.image_mobile | image_url: width: 1200 | image_tag: class: 'mar26-hero-bg-img mar26-hero-bg-mobile', loading: 'eager' }}
    {%- endif -%}
    <div class="mar26-hero-overlay"></div>
  </div>

  <div class="mar26-hero-inner">
    {%- if section.settings.badge_text != blank -%}
      <div class="mar26-hero-badge">
        <div class="mar26-hero-badge-icon">
          <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        </div>
        {{ section.settings.badge_text | escape }}
      </div>
    {%- endif -%}

    <h1 class="mar26-hero-title">
      {{ section.settings.title_main | escape }}<br>
      <span class="mar26-hero-title-accent">{{ section.settings.title_accent | escape }}</span>
    </h1>

    {%- if section.settings.description != blank -%}
      <p class="mar26-hero-desc">
        {{ section.settings.description | escape }}
      </p>
    {%- endif -%}

    <div class="mar26-hero-actions">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="mar26-hero-cta">
          {{ section.settings.cta_text | escape }}
        </a>
      {%- endif -%}
      
      <div class="mar26-hero-price-stack">
        <span class="mar26-hero-price-now">{{ section.settings.price_now }} <span>{{ section.settings.currency_code }}</span></span>
        {%- if section.settings.price_was != blank -%}
          <span class="mar26-hero-price-was">Value {{ section.settings.price_was }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "MAR26 Bestseller Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Visuals"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background Image (Mobile)"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Absolute Best Seller"
    },
    {
      "type": "text",
      "id": "title_main",
      "label": "Primary Title",
      "default": "Caravan Cleaning"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Accent Title",
      "default": "Bundle"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Space is a premium on the road. The Caravan Cleaning Bundle is your hygienic, durable, and space-saving alternative to bulky traditional mops."
    },
    {
      "type": "header",
      "content": "Pricing & CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Unlock the Bundle"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "price_now",
      "label": "Current Price",
      "default": "$189.95"
    },
    {
      "type": "text",
      "id": "price_was",
      "label": "Original Value",
      "default": "$234.95"
    },
    {
      "type": "text",
      "id": "currency_code",
      "label": "Currency Code",
      "default": "AUD"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Red)",
      "default": "#f81b27"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#fba5ac"
    }
  ],
  "presets": [
    {
      "name": "MAR26 Bestseller Hero"
    }
  ]
}
{% endschema %}
