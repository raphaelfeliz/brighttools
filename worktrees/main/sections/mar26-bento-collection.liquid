<style>
  #shopify-section-{{ section.id }} {
    --media-grid-row-height: {{ section.settings.mobile_row_height }}px;
    max-width: calc(1300px + 48px);
    margin: 24px auto !important;
    padding: 0 24px;
    box-sizing: border-box;
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      --media-grid-row-height: {{ section.settings.desktop_row_height }}px;
      margin: 24px auto !important;
      padding: 0 24px;
    }
  }

  {%- for block in section.blocks -%}
    #media-grid-{{ block.id }} {
      --content-over-media-overlay: {{ block.settings.overlay_color.rgb }} /{{ block.settings.overlay_opacity | divided_by: 100.0 }};

      {%- if block.settings.heading_tag == 'h5' or block.settings.heading_tag == 'h6' -%}
        --content-over-media-gap: 1rem;
      {%- endif -%}
    }

    {%- if block.settings.heading_tag == 'h5' or block.settings.heading_tag == 'h6' -%}
      @media screen and (min-width: 740px) {
        #media-grid-{{ block.id }} {
          --content-over-media-gap: 1.5rem;
        }
      }
    {%- endif -%}
  {%- endfor -%}

  #shopify-section-{{ section.id }} .mar26-section {
    font-family: var(--mar26-font-stack);
  }
  #shopify-section-{{ section.id }} .media-grid__item.group {
    border-radius: 1.25rem; /* Standardized brand radius (20px) */
    transition: all 500ms ease;
    background-color: #18181b; /* zinc-900 */
    overflow: hidden;
  }

  /* HOVER: Elevate & Border Glow */
  #shopify-section-{{ section.id }} .media-grid__item.group:hover {
    transform: translateY(-4px);
    box-shadow: var(--mar26-shadow-stronger) !important;
  }

  /* MEDIA SCALING */
  #shopify-section-{{ section.id }} .content-over-media__media {
    transition: transform 700ms ease-out !important;
    opacity: 0.9;
  }

  #shopify-section-{{ section.id }} .media-grid__item.group:hover .content-over-media__media {
    transform: scale(1.1) !important;
  }

  /* OVERLAY DARKENING */
  /* Shopify's base content-over-media uses ::after for the overlay */
  #shopify-section-{{ section.id }} .content-over-media::after {
    transition: opacity 500ms ease !important;
    /* Force initial opacity if missing */
    opacity: 0.6; 
  }

  #shopify-section-{{ section.id }} .media-grid__item.group:hover .content-over-media::after {
    opacity: 0.8 !important;
  }


  /* MOBILE: 2-column grid with per-tile column span control */
  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .media-grid {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      grid-auto-rows: auto !important;
      gap: 0.5rem !important;
    }
    #shopify-section-{{ section.id }} .media-grid__item {
      grid-column: span var(--media-grid-mobile-column-span, 2) !important;
      grid-row: span 1 !important;
      width: 100% !important;
      aspect-ratio: 1 / 1 !important;
      height: auto !important;
    }
    #shopify-section-{{ section.id }} .content-over-media__media.zoom-image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center !important;
      display: block !important;
    }
  }

  /* Standardized Tag Buttons */
  #shopify-section-{{ section.id }} .m26-btn {
    padding: 0.7rem 1.25rem !important;
    font-size: 0.875rem !important;
    border-radius: 10px !important;
    min-width: 120px;
    justify-content: center;
  }
</style>

