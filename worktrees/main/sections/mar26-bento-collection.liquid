<div class="mar26-section">
  <div class="mar26-container">
    <media-grid class="media-grid" data-mar26-element="bento-grid">
    {%- for block in section.blocks -%}
      <a {% if block.settings.link_url != blank %}href="{{ block.settings.link_url }}"{% endif %} class="media-grid__item shadow group" reveal-js style="--media-grid-column-span: {{ block.settings.desktop_column_span }}; --media-grid-row-span: {{ block.settings.desktop_row_span }}; --media-grid-mobile-column-span: {{ block.settings.mobile_column_span | default: 2 }};" {{ block.shopify_attributes }} data-mar26-element="bento-tile">
        <div id="media-grid-{{ block.id }}" {% render 'surface', class: 'content-over-media rounded', background: block.settings.background, background_gradient: block.settings.background_gradient, text_color: block.settings.text_color %}>
          {%- liquid
            assign loading_strategy = nil
  
            if section.index > 3 or forloop.index > 3
              assign loading_strategy = 'lazy'
            endif
          -%}
          
          {%- case block.type -%}
            {%- when 'image' -%}
              {%- if block.settings.image -%}
                {%- capture sizes -%}(max-width: 699px) 100vw, min({{ 390 | times: block.settings.desktop_column_span }}px, {{ 25 | times: block.settings.desktop_column_span }}vw){%- endcapture -%}
                {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: loading: loading_strategy, sizes: sizes, widths: '200,300,400,500,600,700,800,1000,1200,1400,1600,1800,2000,2200,2400', class: 'content-over-media__media zoom-image' -}}
              {%- endif -%}

            {%- when 'video' -%}
              {%- if block.settings.video -%}
                <video-media autoplay style="--aspect-ratio: auto">
                  {%- if block.settings.show_video_controls -%}
                    {%- assign loop_video = false -%}
                  {%- else -%}
                    {%- assign loop_video = true -%}
                  {%- endif -%}

                  {{- block.settings.video | video_tag: playsinline: true, muted: true, loop: loop_video, controls: block.settings.show_video_controls, preload: 'metadata', class: 'object-fill' -}}
                </video-media>
              {%- else -%}
                <video-media host="{{ block.settings.external_video_url.type }}" autoplay style="--aspect-ratio: auto">
                  <template>
                    {%- if block.settings.external_video_url.type == 'youtube' -%}
                      <iframe src="https://www.youtube.com/embed/{{ block.settings.external_video_url.id }}?playsinline=1&autoplay=1&controls=0&mute=1&loop=1&playlist={{ block.settings.external_video_url.id }}&enablejsapi=1&rel=0&modestbranding=1&origin={{ 'https://' | append: request.host | url_encode }}" allow="autoplay; encrypted-media" allowfullscreen="allowfullscreen"></iframe>
                    {%- elsif block.settings.external_video_url.type == 'vimeo' -%}
                      <iframe src="https://player.vimeo.com/video/{{ block.settings.external_video_url.id }}?autoplay=1&autopause=1&background=1&loop=1&muted=1&transparent=0&responsive=1&portrait=0&title=0&byline=0&color={{ settings.text_color | remove_first: '#' }}" allow="autoplay; encrypted-media;" allowfullscreen="allowfullscreen"></iframe>
                    {%- endif -%}
                  </template>
                </video-media>
              {%- endif -%}
          {%- endcase -%}

          {%- if block.settings.title != blank or block.settings.link_text != blank -%}
            <div class="{{ block.settings.mobile_text_position }} {{ block.settings.desktop_text_position }}">
              <div class="prose">
                  {%- liquid
                    assign badge_bg = '#f81b27'
                    assign category_text = block.settings.title | default: block.settings.link_text | downcase
                    
                    if category_text contains 'dustpan'
                      assign badge_bg = '#000000'
                    elsif category_text contains 'window'
                      assign badge_bg = '#13809e'
                    elsif category_text contains 'mop'
                      assign badge_bg = '#fba5ac'
                    elsif category_text contains 'broom'
                      assign badge_bg = '#3762a9'
                    elsif category_text contains 'wipe'
                      assign badge_bg = '#9a69a7'
                    elsif category_text contains 'squeegee'
                      assign badge_bg = '#7c7c7c'
                    elsif category_text contains 'cloth' or category_text contains 'microfiber'
                      assign badge_bg = '#65b2a5'
                    elsif category_text contains 'toilet'
                      assign badge_bg = '#dcb335'
                    elsif category_text contains 'product'
                      assign badge_bg = '#8daedc'
                    endif
                    # Allow manual override if set in block settings
                    if block.settings.button_background != blank and block.settings.button_background != 'rgba(0,0,0,0)' and block.settings.button_background != '#000000'
                       assign badge_bg = block.settings.button_background
                    endif
                  -%}
                {%- if block.settings.title != blank -%}

                  <div class="mar26-big-tag-wrap" style="margin-bottom: 1.5rem;">
                    <span class="m26-btn" style="background-color: {{ badge_bg }}; color: var(--mar26-clr-white); pointer-events: none; border: none; font-size: clamp(1rem, 2vw, 1.25rem) !important; padding: 6px 16px !important; border-radius: 10px !important; box-shadow: var(--mar26-shadow-light);">
                      {% render 'styled-text', content: block.settings.title, gradient: block.settings.text_gradient %}
                    </span>
                  </div>
                {%- endif -%}

                {%- if block.settings.link_text != blank -%}
                  <div class="m26-btn" style="background-color: {{ badge_bg }}; color: var(--mar26-clr-white); border: none; box-shadow: var(--mar26-shadow-light); border-radius: 10px !important;">
                    <span class="m26-btn__text" style="text-transform: uppercase; font-weight: 800;">{{ block.settings.link_text }}</span>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </media-grid>
  </div>
</div>

