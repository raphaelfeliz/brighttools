      "label": "Image"
    },
    {
      "type": "url",
      "id": "card_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "image_picker",
      "id": "card_2_image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "card_2_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "image_picker",
      "id": "card_3_image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "card_3_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 4"
    },
    {
      "type": "image_picker",
      "id": "card_4_image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "card_4_link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "MAR26 Media Grid",
      "settings": {
        "btn_text": "SHOP WIPES",
        "btn_bg_color": "#9a69a7"
      }
    }
