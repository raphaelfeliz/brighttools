{% doc %}
  @prompt
    CREATE A SIMPLE IMAGE SECTION WITH MAX WIDTH OF 80% OF THE VIEWPORT ON DESKTOP AND FULL WIDTH (NO MARGIN AND RESPECT NO PADDING) ON MOIBLE. BORDER RADIUS ON DESKTOP AND STRAIGHT BORDER ON MOBILE., ON MOBILE IT SHOULD BE TRULY NO MARGIN OR PADDING, BLEED ON THE SCREEN., AS YOU CAN SEE, IT IS STILL RESPECTING SOME KIND OF PADDING OR ITS OWN MARGIN OR EQUIVALENT, LET IT BLEED TO THE EDGE OF TH PAGE. 
{% enddoc %}

{% comment %}
  Version: 1.4.0
  Change: Auto-disable border-radius when banner fills the viewport, applying roundness only when boxed.
{% endcomment %}

{% assign section_id = section.id | replace: '_', '' | downcase %}

{% style %}
  /* Force outer Shopify section wrapper to stretch full viewport width with no padding when full_width is true */
  #shopify-section-{{ section.id }} {
    {% if section.settings.full_width %}
      margin: 0 !important;
      padding: 0 !important;
      width: 100vw;
      max-width: 100%;
      overflow: hidden;
    {% else %}
      margin: var(--spacing-6) auto !important;
      padding: 0 var(--spacing-6) !important;
      width: 100% !important;
      max-width: var(--page-width);
      box-sizing: border-box;
    {% endif %}
  }

  .mar26-simple-image-{{ section_id }} {
    display: block;
    width: 100%;
  }

  .mar26-simple-image-wrapper-{{ section_id }} {
    width: 100%;
    margin: 0 auto;
    overflow: hidden;
    {% unless section.settings.full_width %}
      border-radius: {{ section.settings.border_radius }}px;
    {% endunless %}
  }

  .mar26-simple-image-wrapper-{{ section_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .mar26-simple-image-placeholder-{{ section_id }} {
    background-color: #f4f4f4;
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    {% unless section.settings.full_width %}
      border-radius: {{ section.settings.border_radius }}px;
    {% endunless %}
  }

  .mar26-simple-image-placeholder-{{ section_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .mar26-simple-image-empty-state-{{ section_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .mar26-simple-image-wrapper-{{ section_id }} {
      max-width: {{ section.settings.max_width }}px;
    }
  }

  /* Only apply border roundness when screen width exceeds the max-width limit (boxed mode) */
  {% if section.settings.full_width %}
    @media screen and (min-width: {{ section.settings.max_width | plus: 1 }}px) {
      .mar26-simple-image-wrapper-{{ section_id }} {
        border-radius: {{ section.settings.border_radius }}px;
      }

      .mar26-simple-image-placeholder-{{ section_id }} {
        border-radius: {{ section.settings.border_radius }}px;
      }
    }

    @media screen and (max-width: 749px) {
      .mar26-simple-image-{{ section_id }} {
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        width: 100vw;
        max-width: 100vw;
      }

      .mar26-simple-image-wrapper-{{ section_id }} {
        max-width: 100vw;
        width: 100vw;
        border-radius: 0;
        margin: 0;
        padding: 0;
      }

      .mar26-simple-image-wrapper-{{ section_id }} img {
        border-radius: 0;
      }

      .mar26-simple-image-placeholder-{{ section_id }} {
        border-radius: 0;
      }
    }
  {% endif %}
{% endstyle %}

<div class="mar26-simple-image-{{ section_id }}" {{ section.shopify_attributes }}>
  <div class="mar26-simple-image-wrapper-{{ section_id }}">
    {% if section.settings.image %}
      <picture>
        {% if section.settings.mobile_image != blank %}
          <source
            media="(max-width: 749px)"
            srcset="{{ section.settings.mobile_image | image_url: width: 1200 }}"
            width="{{ section.settings.mobile_image.width }}"
            height="{{ section.settings.mobile_image.height }}"
          >
        {% endif %}
        <img
          src="{{ section.settings.image | image_url: width: 2000 }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      </picture>
    {% else %}
      <div class="mar26-simple-image-placeholder-{{ section_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="mar26-simple-image-empty-state-{{ section_id }}">
          Add an image
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "MAR26 Top Image",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image (Optional)",
      "info": "Optional mobile-optimized image. Falls back to desktop image if left blank."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Widescreen max width (desktop)",
      "min": 1000,
      "max": 3000,
      "step": 50,
      "unit": "px",
      "default": 3000
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius (desktop)",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "MAR26 Top Image"
    }
  ]
}
{% endschema %}
