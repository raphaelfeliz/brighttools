{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
MAR26 WINDOW COLLECTION MOCKUP (STANDARD CSS VERSION)
VERSION: 1.5.6 - view btn on mobile
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap');
    
    #shopify-section-{{ section.id }} {
        margin: 0 !important;
        padding: 0 !important;
        width: 100vw;
        max-width: 100%;
        overflow-x: hidden;
        font-family: 'Inter', sans-serif;
    }

    #shopify-section-{{ section.id }} * {
        box-sizing: border-box;
    }

    .mar26-col-wrapper {
        background-color: #f8fafc;
        color: #0f172a;
        min-height: 100vh;
        position: relative;
        display: block;
        overflow-x: hidden;
    }

    .mar26-col-grain-bg {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        opacity: 0.03;
        pointer-events: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
    }

    .mar26-col-main {
        width: 100%;
        max-width: 1440px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 1rem;
        padding-right: 1rem;
        padding-bottom: 4rem;
        position: relative;
        z-index: 10;
        padding-top: 0;
    }

    @media (min-width: 640px) {
        .mar26-col-main { padding-left: 1.5rem; padding-right: 1.5rem; }
    }
    @media (min-width: 1024px) {
        .mar26-col-main { padding-left: 2rem; padding-right: 2rem; }
    }

    /* Hero Unit (Image Stacked) */
    .mar26-hero-unit {
        width: calc(100% + 2rem);
        max-width: none;
        margin-left: -1rem;
        margin-right: -1rem;
        margin-bottom: 0;
        border-radius: 0;
        overflow: hidden;
        box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.2);
        background-color: #f1f5f9;
        display: block;
    }
    @media (min-width: 640px) {
        .mar26-hero-unit {
            width: 100%;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
            border-bottom-left-radius: 24px;
            border-bottom-right-radius: 24px;
            margin-bottom: 2.4rem;
        }
    }

    .mar26-col-hero {
        position: relative;
        width: 100%;
        overflow: hidden;
        display: block;
    }
    .mar26-col-hero img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 700ms ease-in-out;
    }
    .mar26-col-hero:hover img {
        transform: scale(1.05);
    }

    .mar26-col-hero-overlay {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(to bottom right, rgba(37, 99, 235, 0.3) 0%, transparent 100%);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0.4rem;
        overflow: visible;
        pointer-events: none;
        z-index: 30;
    }
    @media (min-width: 640px) { .mar26-col-hero-overlay { padding: 1.2rem; } }
    @media (min-width: 768px) { .mar26-col-hero-overlay { padding: 2.4rem; } }

    .mar26-col-hero-content {
        max-width: 25.6rem;
        position: relative;
        z-index: 40;
        transform: translateY(-0.4rem);
        display: flex;
        flex-direction: column;
        gap: 0.16rem;
    }
    @media (min-width: 640px) {
        .mar26-col-hero-content {
            transform: translateY(-0.8rem);
            gap: 0.6rem;
        }
    }

    .mar26-col-hero-badge {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }
    .mar26-col-hero-badge span:first-child {
        width: 1.6rem; height: 0.2rem; background-color: #ffffff; border-radius: 9999px; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }
    .mar26-col-hero-badge span:last-child {
        color: white; font-weight: 900; letter-spacing: 0.3em; font-size: 8px; text-transform: uppercase; filter: drop-shadow(0 4px 3px rgb(0 0 0 / 0.07)) drop-shadow(0 2px 2px rgb(0 0 0 / 0.06));
    }
    @media (min-width: 768px) { .mar26-col-hero-badge span:last-child { font-size: 0.6rem; } }

    .mar26-col-hero-title {
        font-size: 1.9rem; line-height: 1; font-weight: 900; letter-spacing: -0.05em; color: white; text-transform: uppercase; filter: drop-shadow(0 10px 8px rgb(0 0 0 / 0.04)) drop-shadow(0 4px 3px rgb(0 0 0 / 0.1)); margin: 0; margin-left: 1.5rem;
    }
    .mar26-col-hero-title span {
        color: transparent; background-clip: text; -webkit-background-clip: text; background-image: linear-gradient(to right, #0066FF, #00A3FF); filter: none;
    }
    @media (min-width: 640px) { .mar26-col-hero-title { font-size: 1.6rem; margin-left: 0; } }
    @media (min-width: 768px) { .mar26-col-hero-title { font-size: 3.2rem; } }

    /* Filters Section */
    .mar26-col-filters-sec {
        margin-left: -1rem; margin-right: -1rem; max-width: 1440px; width: auto; background-color: white; border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); position: relative; z-index: 10; padding-left: 0; padding-right: 0; padding-top: 1rem; padding-bottom: 1rem; margin-bottom: 3rem; display: flex; flex-direction: column; justify-content: flex-start; gap: 1.5rem;
    }
    @media (min-width: 640px) {
        .mar26-col-filters-sec { 
            margin-left: auto; 
            margin-right: auto; 
            width: 100%; 
            padding-left: 1.5rem; 
            padding-right: 1.5rem;
            border: 1px solid #e2e8f0;
            border-radius: 3px;
        }
    }
    @media (min-width: 1024px) {
        .mar26-col-filters-sec { flex-direction: row; align-items: center; padding-left: 2rem; padding-right: 2rem; }
    }

    .mar26-col-primary-filters {
        display: flex; flex-direction: row; flex-wrap: wrap; align-items: center; gap: 0.5rem; width: 100%; justify-content: center; padding-left: 1rem; padding-right: 1rem;
    }
    @media (min-width: 640px) { .mar26-col-primary-filters { padding-left: 0; padding-right: 0; } }
    @media (min-width: 1024px) { .mar26-col-primary-filters { flex: 1; gap: 1rem; width: auto; justify-content: flex-start; } }

    .mar26-col-filter-label {
        font-size: 10px; font-weight: 900; color: #2563eb; letter-spacing: 0.2em; text-transform: uppercase; flex-shrink: 0; width: 100%; text-align: center;
    }
    @media (min-width: 1024px) { .mar26-col-filter-label { width: auto; text-align: left; } }
    @media (min-width: 768px) { .mar26-col-filter-label { font-size: 0.75rem; } }

    .mar26-col-filter-btn {
        padding: 0.25rem 0.5rem; border-radius: 0.75rem; border: 1px solid #e2e8f0; background-color: white; transition: background-color 150ms; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: inherit; cursor: pointer;
    }
    .mar26-col-filter-btn:hover { border-color: #cbd5e1; }
    .mar26-col-filter-btn.active { background-color: #0f172a !important; color: white !important; border-color: #0f172a !important; }
    @media (min-width: 768px) { .mar26-col-filter-btn { border-radius: 9999px; font-size: 0.75rem; } }

    /* Secondary Filters */
    .mar26-col-secondary-sec {
        display: flex; flex-direction: row; flex-wrap: wrap; align-items: center; gap: 0.5rem; transition: opacity 300ms; width: 100%; margin-top: 0.5rem; padding-top: 1rem; border-top: 1px solid #f1f5f9; justify-content: center; padding-left: 1rem; padding-right: 1rem;
    }
    @media (min-width: 1024px) { .mar26-col-secondary-sec { gap: 0.75rem; width: auto; margin-top: 0; padding-top: 0; border-top: none; justify-content: flex-start; } }
    @media (min-width: 640px) { .mar26-col-secondary-sec { padding-left: 0; padding-right: 0; } }
    
    .mar26-col-secondary-sec.hidden { display: none; }

    .mar26-col-secondary-wrap {
        display: flex; flex-direction: row; flex-wrap: wrap; align-items: center; background-color: transparent; padding: 0; gap: 0.5rem; border-radius: 0; width: auto; justify-content: center;
    }
    @media (min-width: 1024px) { .mar26-col-secondary-wrap { background-color: transparent; padding: 0; gap: 0.5rem; border-radius: 0; justify-content: flex-start; } }

    .mar26-col-subfilter-btn {
        padding: 0.25rem 0.5rem; border-radius: 0.75rem; border: 1px solid #e2e8f0; background-color: white; color: #334155; transition: background-color 150ms; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; display: flex; align-items: center; justify-content: center; gap: 0.25rem; cursor: pointer;
    }
    .mar26-col-subfilter-btn:hover { color: #0f172a; border-color: #cbd5e1; }
    .mar26-col-subfilter-btn.mar26-active-dark { background-color: #0f172a !important; color: white !important; border-color: #0f172a !important; }

    @media (min-width: 768px) { .mar26-col-subfilter-btn { border-radius: 9999px; font-size: 0.75rem; } }

    /* Grid Area */
    .mar26-col-grid-area { width: 100%; position: relative; z-index: 10; }
    
    .mar26-col-grid-header {
        display: flex; flex-direction: column; align-items: flex-start; margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid #e2e8f0;
    }
    @media (min-width: 768px) { .mar26-col-grid-header { flex-direction: row; justify-content: space-between; align-items: center; } }

    .mar26-col-grid-title-wrap { text-align: left; }
    @media (min-width: 768px) { .mar26-col-grid-title-wrap { text-align: left; } }

    .mar26-col-grid-title { font-size: 1.5rem; font-weight: 900; text-transform: uppercase; letter-spacing: -0.05em; color: #2563eb; margin: 0; }
    .mar26-col-grid-title span.theme-text { color: transparent; background-clip: text; -webkit-background-clip: text; }
    
    .mar26-col-grid-desc { font-size: 0.75rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.2em; color: #334155; margin-top: 0.5rem; max-width: 42rem; margin-bottom: 0; }

    .mar26-col-count-wrap { margin-top: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    @media (min-width: 768px) { .mar26-col-count-wrap { margin-top: 0; } }

    .mar26-col-pulse-dot { width: 0.5rem; height: 0.5rem; border-radius: 9999px; background-color: #e11d48; animation: pulse-dot 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: .5; } }

    .mar26-col-count-text { font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.2em; color: #475569; }

    .mar26-col-grid {
        display: grid; grid-template-columns: repeat(1, minmax(0, 1fr)); gap: 1rem;
    }
    @media (min-width: 768px) { .mar26-col-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.5rem; } }
    @media (min-width: 1024px) { .mar26-col-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

    /* Category Banner */
    .mar26-cat-banner {
        grid-column: 1 / -1; margin-top: 2.5rem; margin-bottom: 1rem; padding: 1.5rem; border-radius: 1rem; border: 2px solid; position: relative; overflow: hidden; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); transition: box-shadow 300ms; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; gap: 1rem; text-align: center;
    }
    @media (min-width: 640px) { .mar26-cat-banner { padding: 2rem; } }
    @media (min-width: 768px) { .mar26-cat-banner { flex-direction: row; gap: 1.5rem; text-align: left; } }
    .mar26-cat-banner:hover { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
    .mar26-cat-banner-bg { position: absolute; inset: 0; background-image: linear-gradient(to bottom right, rgba(255,255,255,0.4), transparent); z-index: 0; opacity: 0.5; }
    .mar26-cat-banner-content { position: relative; z-index: 10; display: flex; flex-direction: column; align-items: center; width: 100%; gap: 1.5rem; }
    @media (min-width: 768px) { .mar26-cat-banner-content { flex-direction: row; flex: 1; align-items: center; gap: 2.5rem; } }
    .mar26-cat-banner-img { width: 100%; flex-shrink: 0; border-radius: 0.75rem; overflow: hidden; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); background-color: white; }
    @media (min-width: 640px) { .mar26-cat-banner-img { width: 66.666667%; } }
    @media (min-width: 768px) { .mar26-cat-banner-img { width: 22%; } }
    .mar26-cat-banner-img img { width: 100%; height: auto; object-fit: cover; aspect-ratio: 1 / 1; mix-blend-mode: multiply; }
    .mar26-cat-banner-text { flex: 1; display: flex; flex-direction: column; align-items: center; }
    @media (min-width: 768px) { .mar26-cat-banner-text { align-items: flex-start; } }
    .mar26-cat-banner-badge { display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-bottom: 0.5rem; }
    @media (min-width: 768px) { .mar26-cat-banner-badge { justify-content: flex-start; margin-bottom: 0.75rem; } }
    .mar26-cat-banner-badge-line { width: 1.5rem; height: 0.25rem; border-radius: 9999px; }
    .mar26-cat-banner-badge-text { font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.2em; }
    .mar26-cat-banner-title { font-size: 1.25rem; font-weight: 900; text-transform: uppercase; letter-spacing: -0.05em; margin-bottom: 0.5rem; margin-top: 0;}
    @media (min-width: 640px) { .mar26-cat-banner-title { font-size: 1.5rem; } }
    @media (min-width: 768px) { .mar26-cat-banner-title { font-size: 1.875rem; } }
    .mar26-cat-banner-desc { font-size: 10px; font-weight: 700; letter-spacing: 0.025em; max-width: 32rem; margin: 0; }

    @media (min-width: 640px) { .mar26-cat-banner-desc { font-size: 0.75rem; } }

    .mar26-cat-video-placeholder {
        grid-column: 1 / -1;
        margin-bottom: 1.5rem;
        width: 100%;
    }

    .mar26-cat-video-placeholder video {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 0.75rem;
        background: #000;
    }

    /* Product Card */
    .mar26-card { 
        position: relative; display: flex; flex-direction: row; border-radius: 1rem; overflow: hidden; height: auto; transition: transform 300ms; background-color: white; border: 2px solid; 
    }
    .mar26-card:hover { transform: translateY(-0.25rem); }
    @media (min-width: 640px) { .mar26-card { flex-direction: column; height: 100%; } }

    .mar26-card-img-wrap { 
        position: relative; width: 40%; aspect-ratio: 1 / 1; background-color: #f9fafb; border-right: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: center; padding: 0; flex-shrink: 0; 
    }
    @media (min-width: 640px) { .mar26-card-img-wrap { width: 100%; border-right: none; border-bottom: 1px solid #f1f5f9; } }
    
    .mar26-card-badge { position: absolute; top: 0.75rem; left: 0.75rem; background-color: #0f172a; color: white; font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.2em; padding: 0.375rem 0.75rem; border-radius: 9999px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); z-index: 20; }
    
    .mar26-card-img { width: 100%; height: 100%; object-fit: contain; padding: 0.75rem; mix-blend-mode: multiply; transition: transform 500ms; }
    .mar26-card:hover .mar26-card-img { transform: scale(1.05); }
    @media (min-width: 640px) { .mar26-card-img { padding: 1rem; } }

    .mar26-card-content { padding: 1rem; display: flex; flex-direction: column; flex-grow: 1; text-align: left; width: 60%; }
    @media (min-width: 640px) { .mar26-card-content { padding: 1.25rem; width: 100%; } }

    .mar26-card-category { font-size: 8px; font-weight: 900; margin-bottom: 0.25rem; letter-spacing: 0.2em; text-transform: uppercase; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
    @media (min-width: 640px) { .mar26-card-category { font-size: 9px; } }

    .mar26-card-title { font-size: 0.875rem; font-weight: 900; line-height: 1.25; margin-bottom: 0.25rem; margin-top: 0; transition: color 150ms; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .mar26-card:hover .mar26-card-title { color: #475569; }
    @media (min-width: 640px) { .mar26-card-title { font-size: 1.125rem; -webkit-line-clamp: unset; display: block; } }

    .mar26-card-specs { font-size: 9px; color: #334155; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; margin-bottom: 0.75rem; margin-top: 0; }
    @media (min-width: 640px) { .mar26-card-specs { font-size: 10px; margin-bottom: 1rem; } }

    .mar26-card-footer { margin-top: auto; padding-top: 0.75rem; border-top: 1px dashed #e2e8f0; }
    @media (min-width: 640px) { .mar26-card-footer { padding-top: 1rem; } }

    .mar26-card-price-wrap { margin-bottom: 0.5rem; display: flex; align-items: center; justify-content: space-between; }
    @media (min-width: 640px) { .mar26-card-price-wrap { margin-bottom: 0.75rem; display: block; } }

    .mar26-card-price { font-size: 1rem; font-weight: 900; color: #0f172a; }
    @media (min-width: 640px) { .mar26-card-price { font-size: 1.25rem; } }

    .mar26-card-actions { display: flex; flex-direction: row; gap: 0.375rem; }
    @media (min-width: 640px) { .mar26-card-actions { display: flex; gap: 0.5rem; } }

    #shopify-section-{{ section.id }} button.mar26-card-btn-add { flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.375rem; background-color: #0f172a; color: white; padding: 0.5rem 0.5rem; border-radius: 0.75rem; font-weight: 700; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; transition: background-color 150ms; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); cursor: pointer; border: none; min-height: 0; height: auto; line-height: 1.2; }
    #shopify-section-{{ section.id }} button.mar26-card-btn-add:hover { background-color: #334155; }
    @media (min-width: 640px) { #shopify-section-{{ section.id }} button.mar26-card-btn-add { flex: 4; gap: 0.5rem; padding: 0.45rem 0.75rem; font-size: 11px; } }
    #shopify-section-{{ section.id }} .mar26-card-btn-add svg,
    #shopify-section-{{ section.id }} .mar26-card-btn-view svg { width: 14px; height: 14px; flex-shrink: 0; }

    #shopify-section-{{ section.id }} button.mar26-card-btn-view { display: flex; flex: 0 0 auto; width: 36px; padding: 0.5rem; justify-content: center; align-items: center; background-color: #f8fafc; color: #1e293b; border: 1px solid #e2e8f0; border-radius: 0.75rem; cursor: pointer; height: auto; transition: background-color 150ms; }
    #shopify-section-{{ section.id }} button.mar26-card-btn-view:hover { background-color: #f1f5f9; }
    #shopify-section-{{ section.id }} button.mar26-card-btn-view span { display: none; }

    @media (min-width: 640px) { 
        #shopify-section-{{ section.id }} button.mar26-card-btn-view { 
            flex: 1; width: auto; padding: 0.45rem 0.75rem; gap: 0.375rem;
        }
        #shopify-section-{{ section.id }} button.mar26-card-btn-view span { display: inline; font-weight: 700; font-size: 11px; text-transform: uppercase; }
    }

    /* Readability floor for compact UI labels/buttons. Hero title remains unchanged. */
    #shopify-section-{{ section.id }} .mar26-col-filter-label,
    #shopify-section-{{ section.id }} .mar26-col-filter-btn,
    #shopify-section-{{ section.id }} .mar26-col-subfilter-btn,
    #shopify-section-{{ section.id }} .mar26-col-count-text,
    #shopify-section-{{ section.id }} .mar26-cat-banner-badge-text,
    #shopify-section-{{ section.id }} .mar26-cat-banner-desc,
    #shopify-section-{{ section.id }} .mar26-card-badge,
    #shopify-section-{{ section.id }} .mar26-card-category,
    #shopify-section-{{ section.id }} .mar26-card-specs,
    #shopify-section-{{ section.id }} button.mar26-card-btn-add,
    #shopify-section-{{ section.id }} button.mar26-card-btn-view {
        font-size: clamp(0.75rem, 0.72rem + 0.15vw, 0.8125rem);
    }
</style>

<div class="mar26-col-wrapper">
    <div class="mar26-col-grain-bg"></div>

    <main class="mar26-col-main">
        
        <!-- Hero Image -->
        <div class="mar26-hero-unit">
            <div class="mar26-col-hero">
                <img src="https://brighttools.com.au/cdn/shop/files/Artboard_2.png?v=1689430728&width=1400" alt="Magnetic Window Cleaner">
                
                <div class="mar26-col-hero-overlay">
                    <div class="mar26-col-hero-content">
                        <h2 class="mar26-col-hero-title">
                            Glass <br><span>Cleaners</span>
                        </h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Filters - Full Width Vertical Bar -->
        <section class="mar26-col-filters-sec">
            <div class="mar26-col-primary-filters" id="primary-filters">
                <span class="mar26-col-filter-label">Filter</span>
                <button data-filter="all" class="mar26-col-filter-btn active" style="background-color: #0f172a; color: white;">
                    All Tools
                </button>
                <button data-filter="magnetic" class="mar26-col-filter-btn">Magnetic</button>
                <button data-filter="reach" class="mar26-col-filter-btn">High Reach</button>
                <button data-filter="handheld" class="mar26-col-filter-btn">Handheld</button>
                <button data-filter="refill" class="mar26-col-filter-btn">Refills</button>
            </div>

            <div id="thickness-section" class="mar26-col-secondary-sec">
                <span class="mar26-col-filter-label">Glass Thickness</span>
                <div class="mar26-col-secondary-wrap" id="secondary-filters">
                    <button data-subfilter="all" class="mar26-col-subfilter-btn mar26-active-dark" style="background-color: #0f172a; color: white; border-color:#0f172a;">
                        All
                    </button>
                    <button data-subfilter="adjustable" class="mar26-col-subfilter-btn">Variable</button>
                    <button data-subfilter="fixed" class="mar26-col-subfilter-btn">Fixed</button>
                </div>
            </div>
        </section>

        <!-- Hidden Category Videos -->
        <div id="mar26-hidden-videos" style="display: none;">
            {%- if section.settings.magnetic_video != blank -%}
                <div data-video-category="magnetic">
                    {{ section.settings.magnetic_video | video_tag: controls: false, autoplay: true, loop: true, muted: true, playsinline: true }}
                </div>
            {%- endif -%}
            {%- if section.settings.reach_video != blank -%}
                <div data-video-category="reach">
                    {{ section.settings.reach_video | video_tag: controls: false, autoplay: true, loop: true, muted: true, playsinline: true }}
                </div>
            {%- endif -%}
            {%- if section.settings.handheld_video != blank -%}
                <div data-video-category="handheld">
                    {{ section.settings.handheld_video | video_tag: controls: false, autoplay: true, loop: true, muted: true, playsinline: true }}
                </div>
            {%- endif -%}
            {%- if section.settings.refill_video != blank -%}
                <div data-video-category="refill">
                    {{ section.settings.refill_video | video_tag: controls: false, autoplay: true, loop: true, muted: true, playsinline: true }}
                </div>
            {%- endif -%}
        </div>

        <!-- Product Grid Area -->
        <section class="mar26-col-grid-area">
            <div class="mar26-col-grid-header">
                <div class="mar26-col-grid-title-wrap">
                    <h2 id="category-title" class="mar26-col-grid-title">All Products</h2>
                    <p id="category-desc" class="mar26-col-grid-desc">Industrial grade window cleaning solutions.</p>
                </div>
                <div class="mar26-col-count-wrap">
                    <span class="mar26-col-pulse-dot"></span>
                    <span id="product-count" class="mar26-col-count-text">11 Products</span>
                </div>
            </div>

            <div id="product-grid" class="mar26-col-grid">
                <!-- Products injected via JS -->
            </div>
        </section>

    </main>
</div>

<script>
    const products = [
        { id: 1, category: 'magnetic', subcategory: 'fixed', name: 'Standard S-1', model: 'Single Glaze', specs: '2–8mm | Thin', price: '$84.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Glider_Classic_S1_01_main_v1.jpg?v=1691496390&width=500' },
        { id: 2, category: 'magnetic', subcategory: 'fixed', name: 'Standard D-2', model: 'Double Glaze', specs: '8–18mm | Standard', price: '$109.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Glider_Classic_D2_magnetic_window_cleaner_01_main_v1.jpg?v=1691497655&width=500' },
        { id: 3, category: 'magnetic', subcategory: 'fixed', name: 'Pro D-3', model: 'Extra-Thick', specs: '20–28mm | Thick', price: '$139.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Glider_Classic_D3_magnetic_window_cleaner_01_main_v3.jpg?v=1691500823&width=500' },
        { id: 4, category: 'magnetic', subcategory: 'fixed', name: 'Classic D-3 Plus', model: 'Triple Glaze', specs: '18–30mm | Advanced', price: '$149.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Glider-D-3-2.jpg?v=1693107647&width=500' },
        { id: 5, category: 'magnetic', subcategory: 'adjustable', name: 'Adjustable AFC-2', model: 'Flex Control', specs: '2–18mm | Variable', price: '$149.95', badge: 'Popular', image: 'https://brighttools.com.au/cdn/shop/files/Glider_Adjustable_D2_AFC_2_18mm_magnetic_window_cleaner_1_1.jpg?v=1686216315&width=500' },
        { id: 6, category: 'magnetic', subcategory: 'adjustable', name: 'Adjustable AFC-3', model: 'Pro Flex', specs: '2–28mm | Variable', price: '$169.95', badge: 'Best Seller', image: 'https://brighttools.com.au/cdn/shop/files/Glider_Adjustable_D3_AFC_2_28mm_magnetic_window_cleaner_1-1.jpg?v=1686214045&width=500' },
        { id: 7, category: 'magnetic', subcategory: 'adjustable', name: 'Heavy-Duty AFC-4', model: 'Max Power', specs: '2–40mm | Maximum', price: '$199.95', badge: 'Max Power', image: 'https://brighttools.com.au/cdn/shop/files/Glider_D4_AFC_2_40_mm_magnetic_window_cleaner_1.jpg?v=1732443899&width=500' },
        { id: 8, category: 'magnetic', subcategory: 'adjustable', name: 'AFC Performer', model: 'Daily Use', specs: '2–28mm | Smooth Track', price: '$159.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/2-18_Glider_06_tyroler_woman.jpg?v=1693107702&width=500' },

        { id: 9, category: 'reach', subcategory: 'none', name: 'Telescopic Pole', model: 'High Reach', specs: 'Exterior Access', price: '$74.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/3_bb7b3f09-5ccf-40be-ae49-05eb5e14983f.jpg?v=1716968374&width=500' },
        { id: 10, category: 'reach', subcategory: 'none', name: 'High Window Washer', model: 'Microfibre Head', specs: 'Soft Lift Reach', price: '$64.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/High_Window_Cleaner_Microfiber.jpg?v=1740832585&width=500' },
        { id: 11, category: 'reach', subcategory: 'none', name: 'Reach Assist Kit', model: 'Window Control', specs: 'Safe Ground Clean', price: '$89.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/83.jpg?v=1689863281&width=500' },
        { id: 12, category: 'reach', subcategory: 'none', name: 'Balcony Glide Reach', model: 'Extended Arm', specs: 'Outdoor Surfaces', price: '$79.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/2-18_Glider_06_tyroler_woman.jpg?v=1693107702&width=500' },
        { id: 13, category: 'reach', subcategory: 'none', name: 'Edge Reach Cleaner', model: 'Slim Head', specs: 'Corners & Frames', price: '$59.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/3_bb7b3f09-5ccf-40be-ae49-05eb5e14983f.jpg?v=1716968374&width=500' },
        { id: 14, category: 'reach', subcategory: 'none', name: 'Exterior Flow Wand', model: 'Quick Rinse', specs: 'Fast Pass Finish', price: '$69.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/High_Window_Cleaner_Microfiber.jpg?v=1740832585&width=500' },

        { id: 15, category: 'handheld', subcategory: 'none', name: 'Mini Mop Device', model: 'Handheld', specs: 'Mirrors & Tiles', price: '$54.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Handheld_Silicone_Squeegee_microfiber_cloth_set_main.jpg?v=1745072125&width=500' },
        { id: 16, category: 'handheld', subcategory: 'none', name: '3-in-1 Surface Cleaner', model: 'Compact Pro', specs: 'Glass + Bench + Tile', price: '$49.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Handheld_three_in_one_Surface_Cleaner_main.jpg?v=1761567321&width=500' },
        { id: 17, category: 'handheld', subcategory: 'none', name: 'Silicone Squeegee Set', model: '4 Cloth Bundle', specs: 'Daily Touchups', price: '$39.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Handheld_Silicone_Squeegee_microfiber_cloth_set_four_pack.jpg?v=1745074202&width=500' },
        { id: 18, category: 'handheld', subcategory: 'none', name: 'Counter Squeegee', model: 'Short Handle', specs: 'Kitchen & Shower', price: '$29.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Counter_Squeegee_01_main.jpg?v=1686229163&width=500' },
        { id: 19, category: 'handheld', subcategory: 'none', name: 'Compact Wipe Kit', model: 'Dual Side', specs: 'Dry + Polish', price: '$34.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/01_main_v2.jpg?v=1686228416&width=500' },
        { id: 20, category: 'handheld', subcategory: 'none', name: 'Precision Squeegee', model: 'Detail Edge', specs: 'Narrow Frames', price: '$32.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/01_main_v1.jpg?v=1686218073&width=500' },

        { id: 21, category: 'refill', subcategory: 'none', name: 'Glider Cloths', model: '6-Pack', specs: 'Microfibre Pads', price: 'From $14.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Replacement_Microfibre_Cloth_6_pack_Glider.jpg?v=1740832681&width=500' },
        { id: 22, category: 'refill', subcategory: 'none', name: 'Glider Cloths', model: '4-Pack', specs: 'Replacement Set', price: 'From $12.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Replacement_Microfibre_Cloth_4_pack_Glider.jpg?v=1740832841&width=500' },
        { id: 23, category: 'refill', subcategory: 'none', name: 'Telescopic Cloths', model: '2-Pack', specs: 'Pole Replacements', price: 'From $14.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Replacement-Microfiber_Cleaning_Cloth_Pack_of_2_Pc.webp?v=1716968293&width=500' },
        { id: 24, category: 'refill', subcategory: 'none', name: 'Mini Mop Pads', model: '2 / 4-Pack', specs: 'Handheld Refills', price: 'From $14.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Quick_Mop_Microfibre_Floor_Cloth_Tow_Pack_Main.jpg?v=1770613483&width=500' },
        { id: 25, category: 'refill', subcategory: 'none', name: 'Waffle Finishers', model: '3-Pack', specs: 'Streak-Free Finish', price: '$12.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/sano_microfiber_cloth_master.jpg?v=1709647755&width=500' },
        { id: 26, category: 'refill', subcategory: 'none', name: 'Polish Cloth Bundle', model: 'Multi Surface', specs: 'Washable Microfibre', price: '$19.95', badge: '', image: 'https://brighttools.com.au/cdn/shop/files/Replacement_Microfibre_Cloth_4_pack_Glider.jpg?v=1740832841&width=500' }
    ];

    const sections = [
        { id: 'magnetic', title: 'Magnetic Power', desc: 'Clean both sides of your window simultaneously. Industrial grade magnets for secure tracking.', theme: 'blue', image: 'https://brighttools.com.au/cdn/shop/files/Glider_D4_AFC_2_40_mm_magnetic_window_cleaner_1.jpg?v=1732443899&width=500' },
        { id: 'reach', title: 'High Access Range', desc: 'Engineered for safe ground-level operation. No ladders required.', theme: 'rose', image: 'https://brighttools.com.au/cdn/shop/files/High_Window_Cleaner_Microfiber.jpg?v=1740832585&width=500' },
        { id: 'handheld', title: 'Precision Detailing', desc: 'Compact tools for tactile control on shower glass and mirrors.', theme: 'rose', image: 'https://brighttools.com.au/cdn/shop/files/Handheld_three_in_one_Surface_Cleaner_main.jpg?v=1761567321&width=500' },
        { id: 'refill', title: 'Tactical Refills', desc: 'High-density microfibre for flawless polish.', theme: 'slate', image: 'https://brighttools.com.au/cdn/shop/files/Replacement_Microfibre_Cloth_4_pack_Glider.jpg?v=1740832841&width=500' }
    ];

    let currentFilter = 'all';
    let currentSubfilter = 'all';

    const themeMap = {
        'rose': { bg: 'rgba(225, 29, 72, 0.15)', button: '#e11d48', text: '#e11d48', border: '#fda4af', glow: 'rgba(225,29,72,0.2)' },
        'slate': { bg: 'rgba(71, 85, 105, 0.15)', button: '#334155', text: '#1e293b', border: '#cbd5e1', glow: 'rgba(51,65,85,0.05)' },
        'blue': { bg: 'rgba(0, 163, 255, 0.15)', button: '#2563eb', text: '#2563eb', border: '#93c5fd', glow: 'rgba(37,99,235,0.2)' }
    };

    const sectionRoot = document.getElementById('shopify-section-{{ section.id }}') || document;
    const primaryBtns = sectionRoot.querySelectorAll('.mar26-col-filter-btn');
    const subfilterBtns = sectionRoot.querySelectorAll('.mar26-col-subfilter-btn');
    const thicknessSection = sectionRoot.querySelector('#thickness-section');
    const productGrid = sectionRoot.querySelector('#product-grid');
    const categoryTitle = sectionRoot.querySelector('#category-title');
    const categoryDesc = sectionRoot.querySelector('#category-desc');
    const productCount = sectionRoot.querySelector('#product-count');

    const titles = {
        'all': { title: 'All Products', desc: 'Industrial grade window cleaning solutions.' },
        'magnetic': { title: 'Magnetic Cleaners', desc: 'Clean both sides simultaneously from the inside.' },
        'reach': { title: 'High Reach Tools', desc: 'Telescopic cleaners for upper floors.' },
        'handheld': { title: 'Handheld & Indoor', desc: 'Compact tools for controlled indoor environments.' },
        'refill': { title: 'Cloths & Refills', desc: 'Replacement high-density fabrics.' }
    };

    function extractVideos() {
        // Move videos back to the hidden container before grid is cleared
        const hiddenWrap = sectionRoot.querySelector('#mar26-hidden-videos');
        if (!hiddenWrap) return;
        
        const activeVideos = productGrid.querySelectorAll('.mar26-cat-video-placeholder > div');
        activeVideos.forEach(vid => {
            const cat = vid.parentElement.dataset.placeholderCategory;
            const slot = hiddenWrap.querySelector(`[data-video-category="${cat}"]`);
            if (slot) slot.appendChild(vid);
        });
    }

    function injectVideos() {
        // Move videos from hidden container into the active placeholders
        const hiddenWrap = sectionRoot.querySelector('#mar26-hidden-videos');
        if (!hiddenWrap) return;

        const placeholders = productGrid.querySelectorAll('.mar26-cat-video-placeholder');
        placeholders.forEach(placeholder => {
            const cat = placeholder.dataset.placeholderCategory;
            const slot = hiddenWrap.querySelector(`[data-video-category="${cat}"]`);
            if (slot && slot.firstElementChild) {
                placeholder.appendChild(slot.firstElementChild);
            }
        });
    }

    function renderProducts() {
        extractVideos();
        productGrid.innerHTML = '';

        const visibleSections = currentFilter === 'all'
            ? sections
            : sections.filter(s => s.id === currentFilter);

        let totalVisibleProducts = 0;
        visibleSections.forEach(section => {
            totalVisibleProducts += products.filter(p => {
                if (p.category !== section.id) return false;
                if (section.id === 'magnetic' && currentFilter === 'magnetic' && currentSubfilter !== 'all') {
                    return p.subcategory === currentSubfilter;
                }
                return true;
            }).length;
        });

        productCount.textContent = `${totalVisibleProducts} Product${totalVisibleProducts !== 1 ? 's' : ''}`;

        if (totalVisibleProducts === 0) {
            productGrid.innerHTML = `<div style="grid-column: 1 / -1; padding: 5rem; text-align: center; color: #334155; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; background-color: white; border: 1px solid #e2e8f0; border-radius: 5px;">No tools found matching criteria.</div>`;
            return;
        }

        visibleSections.forEach(section => {
            const sectionProducts = products.filter(p => {
                if (p.category !== section.id) return false;
                if (section.id === 'magnetic' && currentFilter === 'magnetic' && currentSubfilter !== 'all') {
                    return p.subcategory === currentSubfilter;
                }
                return true;
            });
            
            if (sectionProducts.length > 0) {
                const activeTheme = themeMap[section.theme];

                productGrid.innerHTML += `
                    <div class="mar26-cat-banner" style="background-color: #eff6ff; border-color: #93c5fd;">
                        <div class="mar26-cat-banner-bg"></div>

                        <div class="mar26-cat-banner-content">
                            <div class="mar26-cat-banner-img">
                                <img src="${section.image}" alt="${section.title}">
                            </div>
                            <div class="mar26-cat-banner-text">
                                <div class="mar26-cat-banner-badge">
                                    <span class="mar26-cat-banner-badge-line" style="background-color: #3b82f6;"></span>
                                    <span class="mar26-cat-banner-badge-text" style="color: #1e40af;">${section.id} series</span>
                                </div>
                                <h3 class="mar26-cat-banner-title" style="color: #1d4ed8;">${section.title}</h3>
                                <p class="mar26-cat-banner-desc" style="color: #1e40af;">${section.desc}</p>
                            </div>
                        </div>
                    </div>
                    <div class="mar26-cat-video-placeholder" data-placeholder-category="${section.id}"></div>
                `;
                
                sectionProducts.forEach(p => {
                    const isHighlight = (p.category === 'magnetic' && currentSubfilter === 'adjustable' && p.subcategory === 'adjustable');
                    
                    const borderColor = isHighlight ? 'rgba(251, 113, 133, 0.5)' : 'rgba(203, 213, 225, 0.5)';
                    const shadowColor = isHighlight ? 'rgba(225,29,72,0.2)' : 'rgba(51,65,85,0.05)';
                    const bgColor = isHighlight ? 'rgba(255, 241, 242, 0.5)' : 'rgba(248, 250, 252, 0.3)';
                    const titleColor = isHighlight ? '#e11d48' : '#1e293b';

                    const card = `
                        <div class="mar26-card" style="border-color: ${borderColor}; box-shadow: 0 0 20px -5px ${shadowColor}; background-color: ${bgColor};">
                            
                            <div class="mar26-card-img-wrap">
                                ${p.image ? `
                                    <img src="${p.image}" alt="${p.name}" class="mar26-card-img">
                                ` : `
                                    <div style="width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #64748b;">
                                        <span style="font-size: 10px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;">${p.model}</span>
                                    </div>
                                `}
                            </div>
                            
                            <div class="mar26-card-content">
                                <div class="mar26-card-category" style="color: ${activeTheme.text};">${p.category} series</div>
                                <h3 class="mar26-card-title" style="color: ${titleColor};">${p.name}</h3>
                                <p class="mar26-card-specs">${p.specs}</p>
                                
                                <div class="mar26-card-footer">
                                    <div class="mar26-card-price-wrap">
                                        <span class="mar26-card-price">${p.price}</span>
                                    </div>
                                    
                                    <div class="mar26-card-actions">
                                        <button class="mar26-card-btn-add">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                                            <span>Add</span>
                                        </button>
                                        
                                        <button class="mar26-card-btn-view">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                            <span>View</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;

                    productGrid.innerHTML += card;
                });
            }
        });

        injectVideos();
    }

    primaryBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            primaryBtns.forEach(b => {
                b.classList.remove('active');
                b.style.backgroundColor = 'white';
                b.style.color = 'inherit';
            });
            
            const target = e.currentTarget;
            target.classList.add('active');
            target.style.backgroundColor = '#0f172a';
            target.style.color = 'white';

            currentFilter = target.dataset.filter;
            currentSubfilter = 'all'; 

            const foundSection = sections.find(s=>s.id === currentFilter);
            
            if (currentFilter !== 'all') {
                categoryTitle.innerHTML = titles[currentFilter].title + ` <span class="theme-text" style="background-image: linear-gradient(to right, #2563eb, #2563eb);">System</span>`;
            } else {
                categoryTitle.innerHTML = titles[currentFilter].title;
            }
            categoryDesc.textContent = titles[currentFilter].desc;

            if (currentFilter === 'magnetic' || currentFilter === 'all') {
                thicknessSection.classList.remove('hidden');
                thicknessSection.style.opacity = '1';
            } else {
                thicknessSection.classList.add('hidden');
                thicknessSection.style.opacity = '0';
            }

            subfilterBtns.forEach(sb => {
                sb.classList.remove('mar26-active-dark');
                sb.style.backgroundColor = '';
                sb.style.color = '';
                sb.style.borderColor = '';
                if(sb.dataset.subfilter === 'all') {
                    sb.style.backgroundColor = '#0f172a';
                    sb.style.color = 'white';
                    sb.style.borderColor = '#0f172a';
                }
            });

            renderProducts();
        });
    });

    subfilterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            subfilterBtns.forEach(b => {
                b.classList.remove('mar26-active-dark');
                b.style.backgroundColor = '';
                b.style.color = '';
                b.style.borderColor = '';
            });

            const target = e.currentTarget;
            
            if (currentFilter !== 'magnetic') {
                sectionRoot.querySelector('[data-filter="magnetic"]').click();
            }

            target.classList.add('mar26-active-dark');
            target.style.backgroundColor = '#0f172a';
            target.style.color = 'white';
            target.style.borderColor = '#0f172a';

            currentSubfilter = target.dataset.subfilter;
            
            if (currentSubfilter === 'adjustable') {
                categoryTitle.innerHTML = "Variable Strength <span style='color: #2563eb;'>(AFC)</span>";
                categoryDesc.textContent = "Dial in exact magnetic calibration for any thickness up to 40mm.";
            } else if (currentSubfilter === 'fixed') {
                categoryTitle.textContent = "PRE-CALIBRATED SYSTEMS";
                categoryDesc.textContent = "Locked strength variables for confirmed glass formats.";
            } else {
                categoryTitle.textContent = titles['magnetic'].title;
                categoryDesc.textContent = titles['magnetic'].desc;
            }

            renderProducts();
        });
    });

    sectionRoot.querySelector('[data-filter="all"]').style.backgroundColor = '#0f172a';
    sectionRoot.querySelector('[data-filter="all"]').style.color = 'white';
    
    renderProducts();
</script>

{% schema %}
{
  "name": "MAR26 Window Collection",
  "tag": "section",
  "class": "mar26-window-collection-wrap",
    "settings": [
    {
            "type": "video",
            "id": "magnetic_video",
            "label": "Magnetic group video"
    },
    {
            "type": "video",
            "id": "reach_video",
            "label": "High Reach group video"
        },
        {
            "type": "video",
            "id": "handheld_video",
            "label": "Handheld group video"
        },
        {
            "type": "video",
            "id": "refill_video",
            "label": "Refills group video"
    }
  ],
    "blocks": [
        {
            "type": "@app"
        }
    ],
  "presets": [
    {
      "name": "MAR26 Window Collection Mockup"
    }
  ]
}
{% endschema %}
