{% schema %}
{
  "name": "MAR26 Panorama Slices",
  "class": "shopify-section--panorama-slices",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    { "type": "header", "content": "slice 1 > content" },
    { "type": "text", "id": "s1_nav_title", "label": "Tab Title (Mobile)", "default": "BUNDLES" },
    { "type": "text", "id": "s1_title", "label": "Section Title", "default": "VALUE KITS" },
    { "type": "textarea", "id": "s1_desc", "label": "Description", "default": "Curated collections bundled for maximum value." },
    { "type": "select", "id": "s1_bg_active", "label": "Slice Color", "options": [{ "value": "red", "label": "Red" }, { "value": "black", "label": "Black" }, { "value": "teal", "label": "Teal" }, { "value": "pink", "label": "Pink" }, { "value": "blue", "label": "Blue" }, { "value": "purple", "label": "Purple" }, { "value": "grey", "label": "Grey" }], "default": "teal" },
    { "type": "select", "id": "s1_badge_bg", "label": "Title Badge Color", "options": [{ "value": "red", "label": "Red" }, { "value": "black", "label": "Black" }, { "value": "teal", "label": "Teal" }, { "value": "pink", "label": "Pink" }, { "value": "blue", "label": "Blue" }, { "value": "purple", "label": "Purple" }, { "value": "grey", "label": "Grey" }], "default": "red" },
    { "type": "header", "content": "slice 1 > button" },
    { "type": "text", "id": "s1_cta_text", "label": "Button Text", "default": "SHOP BUNDLES" },
    { "type": "url", "id": "s1_cta_link", "label": "Button Link" },
    { "type": "select", "id": "s1_cta_size", "label": "Button Size", "options": [{ "value": "big", "label": "Big" }, { "value": "medium", "label": "Medium" }, { "value": "small", "label": "Small" }], "default": "big" },
    { "type": "color", "id": "s1_cta_bg_color", "label": "Button Background", "default": "#0f172a" },
    { "type": "select", "id": "s1_cta_text_color", "label": "Button Text Color", "options": [{ "value": "white", "label": "White" }, { "value": "black", "label": "Black" }], "default": "white" },
    { "type": "checkbox", "id": "s1_cta_outline", "label": "White Outline Border", "default": false },
    { "type": "checkbox", "id": "s1_cta_hover_activate", "label": "Button Changes on Hover", "default": true },
    { "type": "select", "id": "s1_cta_icon", "label": "Button Icon", "options": [{ "value": "right", "label": "Right Arrow" }, { "value": "left", "label": "Left Arrow" }, { "value": "no", "label": "No Icon" }], "default": "right" },

    { "type": "header", "content": "Card 1" },
    { "type": "image_picker", "id": "s1_c1_img", "label": "Image" },
    { "type": "text", "id": "s1_c1_text", "label": "Label", "default": "Ultra Mop" },
    { "type": "url", "id": "s1_c1_link", "label": "Link" },
    { "type": "header", "content": "Card 2" },
    { "type": "image_picker", "id": "s1_c2_img", "label": "Image" },
    { "type": "text", "id": "s1_c2_text", "label": "Label", "default": "Window Kit" },
    { "type": "url", "id": "s1_c2_link", "label": "Link" },
    { "type": "header", "content": "Card 3" },
    { "type": "image_picker", "id": "s1_c3_img", "label": "Image" },
    { "type": "text", "id": "s1_c3_text", "label": "Label", "default": "Floor Bundle" },
    { "type": "url", "id": "s1_c3_link", "label": "Link" },
    { "type": "header", "content": "Card 4" },
    { "type": "image_picker", "id": "s1_c4_img", "label": "Image" },
    { "type": "text", "id": "s1_c4_text", "label": "Label", "default": "Value Pack" },
