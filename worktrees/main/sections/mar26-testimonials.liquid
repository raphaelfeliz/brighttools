{%- comment -%}
  ----------------------------------------------------------------------------------------------------------------------
  MAR26 REVOLUTION TESTIMONIALS
  VERSION: 1.7.0 - Phase 2 Global CSS Migration
  ----------------------------------------------------------------------------------------------------------------------
  A high-impact, premium testimonial section with an SVG "Revolution" background
  and an infinite-looping spotlight carousel.
{%- endcomment -%}

<script>
  console.log('MAR26 Testimonials - Version: 1.7.0');
</script>

<style>
  /* Base Section Variables & Setup */
  .mar26-revolution-sec {
    position: relative;
    padding-top: 35px;
    padding-bottom: 35px;
    margin-top: 0;
    z-index: 20;
    overflow: hidden;
    background-color: #13809e;
  }

  /* SVG Background Engine Removed */

  /* Global Grain Texture */
  .mar26-global-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.03;
    z-index: 9999;
    mix-blend-mode: multiply;
  }

  @media (max-width: 767px) {
    .mar26-revolution-sec {
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    .mar26-testi-header h2 {
      font-size: 1.5rem !important;
      gap: 0.5rem;
    }

    .mar26-testi-header h2 svg {
      width: 32px !important;
      height: 32px !important;
    }

    .mar26-testi-controls {
      display: none !important;
    }

    .mar26-testi-track-container {
      overflow-x: auto !important;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .mar26-testi-track-container::-webkit-scrollbar {
      display: none;
    }

    .mar26-testi-slide {
      /* Scroll snap removed to fix jumpy marquee on mobile */
    }
  }

  /* Header Styles */
  .mar26-testi-header {
    text-align: center;
    margin-bottom: 1.5rem;
    width: 100%;
    max-width: 64rem;
    padding: 0 1.5rem;
    color: var(--mar26-clr-white);
    margin-left: auto;
    margin-right: auto;
  }

  .mar26-testi-header h2 {
    font-size: 1.8rem;
    font-weight: var(--mar26-fw-extrabold);
    text-transform: uppercase;
    letter-spacing: -0.05em;
    line-height: 1;
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    color: var(--mar26-clr-white);
  }
  @media (min-width: 768px) {
    .mar26-testi-header h2 {
      font-size: 3rem; /* Scaled down 20% */
    }
  }

  .mar26-testi-header p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    font-weight: var(--mar26-fw-medium);
    max-width: 60rem;
    margin: 0 auto;
  }

  /* Carousel Layout */
  .mar26-testimonials-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
  }

  .mar26-testi-track-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding: 2.5rem 0; /* space for scaling */
  }

  .mar26-testi-track {
    display: flex;
    transition: transform ease-out; /* Note: transform is only for desktop arrows, marquee uses scrollLeft */
  }

  .mar26-testi-slide {
    flex-shrink: 0;
    width: 240px; /* Reduced from 300px (20% reduction) */
    padding: 0 5px;
    display: flex;
    box-sizing: border-box;
    justify-content: center;
  }
  @media (min-width: 768px) {
    .mar26-testi-slide {
      width: 272px; /* Reduced from 340px (20% reduction) */
      padding: 0 10px;
    }
  }

  .mar26-testi-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background-color: var(--mar26-clr-white);
    padding: 1.6rem;
    border-radius: 1.2rem;
    border: 2px solid #dbeafe;
    height: 100%;
    justify-content: space-between;
    width: 100%;
    max-width: 256px; /* Reduced from 320px (20% reduction) */
  }

  /* Card Inner Elements */
  .mar26-quote-icon-wrap {
    width: 3.2rem;
    height: 3.2rem;
    background-color: #f1f5f9; /* slate-100 */
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.8rem auto;
    border: 2px solid white;
    box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.05);
  }
  .mar26-quote-icon-wrap svg {
    color: #2563eb; /* blue-600 */
    opacity: 0.5;
  }

  .mar26-stars {
    display: flex;
    justify-content: center;
    gap: 0.25rem;
    margin-bottom: 2rem;
  }
  .mar26-stars svg {
    fill: var(--mar26-clr-pink);
    color: var(--mar26-clr-pink);
  }

  .mar26-content {
    color: #334155; /* slate-700 */
    font-size: 0.9rem;
    font-weight: var(--mar26-fw-medium);
    line-height: 1.625;
    font-style: italic;
    margin-bottom: 1.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .mar26-author-info {
    margin-top: auto;
  }
  .mar26-author-info h4 {
    font-weight: var(--mar26-fw-extrabold);
    color: var(--mar26-clr-black);
    text-transform: uppercase;
    letter-spacing: -0.05em; /* tracking-tighter */
    font-size: 1rem;
    line-height: 1.2;
    margin: 0;
  }
  .mar26-country-chip {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    margin-top: 0.35rem;
    padding: 0.32rem 0.8rem 0.32rem 1.65rem;
    border-radius: 9999px;
    background-color: #f8fafc;
    border: 1px solid #dbeafe;
    color: #334155;
    font-size: 10px;
    font-weight: var(--mar26-fw-extrabold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
  }

  .mar26-country-chip__flag {
    position: absolute;
    left: 0.08rem;
    top: 50%;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 9999px;
    overflow: hidden;
    flex-shrink: 0;
    transform: translateY(-50%);
    transform-origin: center;
  }

  .mar26-country-chip__label {
    display: inline-block;
  }

  .mar26-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--mar26-clr-black);
    color: var(--mar26-clr-white);
    font-size: 9px;
    font-weight: var(--mar26-fw-extrabold);
    text-transform: uppercase;
    letter-spacing: 0.2em; /* tracking-[0.2em] */
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    border: 2px solid white;
    white-space: nowrap;
  }

  /* Controls */
  .mar26-testi-controls {
    position: absolute;
    top: 50%;
    left: 1rem;
    right: 1rem;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    pointer-events: none;
    z-index: 30;
  }
  @media (min-width: 768px) {
    .mar26-testi-controls {
      left: 3rem;
      right: 3rem;
    }
  }

  .mar26-testi-btn {
    pointer-events: auto;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background-color: var(--mar26-clr-black);
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--mar26-clr-white);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .mar26-testi-btn:hover {
    transform: scale(1.1);
  }
  .mar26-testi-btn:active {
    transform: scale(0.95);
  }
  .mar26-testi-btn svg {
    width: 24px;
    height: 24px;
  }
</style>

<section id="shopify-section-{{ section.id }}" class="mar26-revolution-sec" data-section-id="{{ section.id }}">
  {%- comment -%} SVG Background Removed {%- endcomment -%}
  <link rel="stylesheet" href="{{ 'country-flags.css' | asset_url }}" media="print" onload="this.media='all'; this.onload = null">

  {%- comment -%} GLOBAL GRAIN OVELAY {%- endcomment -%}
  {%- capture grain_bg -%}
  data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E
  {%- endcapture -%}
  <div class="mar26-global-grain" style="background-image: url('{{ grain_bg | strip_newlines | remove: ' ' }}');"></div>

  {%- comment -%} MAIN CONTENT {%- endcomment -%}
  <mar26-testimonials class="mar26-testimonials-wrapper" data-total="{{ section.blocks.size }}">
    <header class="mar26-testi-header">
      <h2 class="mar26-title">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="52"
          height="52"
          viewBox="0 0 24 24"
          fill="var(--mar26-clr-pink)"
          stroke="none"
          style="transform: rotate(-15deg); flex-shrink: 0;"
        >
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        {{ section.settings.title | escape }}
      </h2>
      <p>{{ section.settings.subheading | escape }}</p>
    </header>

    <div class="mar26-testi-track-container" data-carousel-container>
      <div class="mar26-testi-track" data-carousel-track>
        {%- if section.blocks.size > 0 -%}
          {%- comment -%}
            We render 3 identical sets of the blocks to allow for seamless infinite scrolling
            in both directions. The JS handles teleporting between sets when thresholds are crossed.
          {%- endcomment -%}
          {%- for i in (1..3) -%}
            {%- for block in section.blocks -%}
              <div class="mar26-testi-slide" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
                <div class="mar26-testi-card">
                  <div class="mar26-badge">Verified User</div>

                  <div>
                    <div class="mar26-quote-icon-wrap">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/>
                      </svg>
                    </div>
                    {%- if block.settings.show_rating -%}
                      <div class="mar26-stars">
                        {%- for r in (1..5) -%}
                          {%- if r <= block.settings.rating -%}
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              width="14"
                              height="14"
                              viewBox="0 0 24 24"
                              fill="currentColor"
                              stroke="none"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                          {%- else -%}
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              width="14"
                              height="14"
                              viewBox="0 0 24 24"
                              fill="none"
                              class="opacity-20"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  </div>

                  <div class="mar26-content">"{{ block.settings.content | strip_html }}"</div>

                  <div class="mar26-author-info">
                    <h4>{{ block.settings.author | escape }}</h4>
                    {%- assign country_value = block.settings.country | default: 'australia' -%}
                    {%- if country_value == 'new_zealand' -%}
                      <span class="mar26-country-chip" aria-label="New Zealand">
                        <span class="country-flags country-flags--NZ mar26-country-chip__flag" aria-hidden="true"></span>
                        <span class="mar26-country-chip__label">New Zealand</span>
                      </span>
                    {%- else -%}
                      <span class="mar26-country-chip" aria-label="Australia">
                        <span class="country-flags country-flags--AU mar26-country-chip__flag" aria-hidden="true"></span>
                        <span class="mar26-country-chip__label">Australia</span>
                      </span>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Empty State Placeholder {%- endcomment -%}
          <div class="mar26-testi-slide is-active">
            <div class="mar26-testi-card">
              <div class="mar26-content mt-10 text-xl font-bold">Add Testimonial Blocks in Editor</div>
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="mar26-testi-controls">
          <button class="mar26-testi-btn" data-prev aria-label="Previous Testimonial">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m15 18-6-6 6-6"/>
            </svg>
          </button>
          <button class="mar26-testi-btn" data-next aria-label="Next Testimonial">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  </mar26-testimonials>
</section>

<script>
  if (!customElements.get('mar26-testimonials')) {
    customElements.define(
      'mar26-testimonials',
      class extends HTMLElement {
        constructor() {
          super();
          this.container = this.querySelector('[data-carousel-container]');
          this.track = this.querySelector('[data-carousel-track]');
          this.slides = Array.from(this.track ? this.track.querySelectorAll('.mar26-testi-slide') : []);
          this.prevBtn = this.querySelector('[data-prev]');
          this.nextBtn = this.querySelector('[data-next]');

          this.total = parseInt(this.getAttribute('data-total') || '0', 10);

          if (this.total === 0 || this.slides.length === 0) return;

          // State Init
          this.isPausedByHover = false;
          this.isPausedByInteraction = false;
          this.interactionTimeout = null;
          this.rafId = null;
          this.lastTimestamp = 0;
          this.scrollPos = 0;
          this.originalWidth = 0;

          // Listeners
          this.prevBtn?.addEventListener('click', () => this.handleManualNav('prev'));
          this.nextBtn?.addEventListener('click', () => this.handleManualNav('next'));

          this.container?.addEventListener('mouseenter', () => (this.isPausedByHover = true));
          this.container?.addEventListener('mouseleave', () => {
            this.isPausedByHover = false;
            this.lastTimestamp = 0;
          });

          this.container?.addEventListener('touchstart', () => this.triggerInteractionPause(), { passive: true });
          this.container?.addEventListener('mousedown', () => this.triggerInteractionPause());

          window.addEventListener('resize', () => this.updateWidths());

          this.init();
        }

        init() {
          this.updateWidths();
          // Start marquee roughly in the middle set
          this.scrollPos = this.originalWidth;
          this.container.scrollLeft = this.scrollPos;

          setTimeout(() => this.startMarquee(), 500);
        }

        updateWidths() {
          // total blocks * item width - the container tripled the blocks
          this.originalWidth = this.track.scrollWidth / 3;
        }

        triggerInteractionPause() {
          this.isPausedByInteraction = true;
          if (this.interactionTimeout) clearTimeout(this.interactionTimeout);

          this.interactionTimeout = setTimeout(() => {
            this.isPausedByInteraction = false;
            this.scrollPos = this.container.scrollLeft;
            this.lastTimestamp = 0;
          }, 2500);
        }

        startMarquee() {
          const step = (timestamp) => {
            if (!this.lastTimestamp) this.lastTimestamp = timestamp;
            const delta = timestamp - this.lastTimestamp;
            this.lastTimestamp = timestamp;

            if (!this.isPausedByHover && !this.isPausedByInteraction) {
              const speed = 0.0512; // Matching marquee speed of other components
              this.scrollPos += speed * delta;

              if (this.scrollPos >= this.originalWidth * 2) {
                this.scrollPos -= this.originalWidth;
              } else if (this.scrollPos < this.originalWidth) {
                this.scrollPos += this.originalWidth;
              }
              this.container.scrollLeft = this.scrollPos;
            }

            this.updateActiveSlide();
            this.rafId = requestAnimationFrame(step);
          };
          this.rafId = requestAnimationFrame(step);
        }

        updateActiveSlide() {
          // All cards styled uniformly — no active tracking needed
        }

        handleManualNav(direction) {
          this.triggerInteractionPause();
          const slideWidth = this.slides[0].offsetWidth;
          const scrollAmount = direction === 'next' ? slideWidth : -slideWidth;

          this.container.scrollBy({ left: scrollAmount, behavior: 'smooth' });

          setTimeout(() => {
            this.scrollPos = this.container.scrollLeft;
          }, 600);
        }
      }
    );
  }
</script>

{% schema %}
{
  "name": "MAR26 Testimonials",
  "class": "shopify-section--testimonials",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What they're saying"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join thousands of homeowners who have elevated their cleaning experience with us."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "MAR26 Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Name",
          "default": "James Anderson"
        },
        {
          "type": "select",
          "id": "country",
          "label": "Country",
          "options": [
            {
              "value": "australia",
              "label": "Australia"
            },
            {
              "value": "new_zealand",
              "label": "New Zealand"
            }
          ],
          "default": "australia"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Quote",
          "default": "<p>The Japanese Rubber Broom changed how I handle large floor areas. It's indispensable.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_rating",
          "label": "Show star rating",
          "default": true
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MAR26 Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "author": "James Anderson",
            "country": "australia",
            "content": "<p>The Japanese Rubber Broom changed how I handle large floor areas. It's indestructible.</p>"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "Sarah Jenkins",
            "country": "new_zealand",
            "content": "<p>I've tried every cleaner on the market, but the Glider S-1 is the only one that delivers.</p>"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "Emma Watson",
            "country": "australia",
            "content": "<p>If you have a dog that sheds, you need these tools. It literally pulls fur out of carpets.</p>"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "Michael Chen",
            "country": "new_zealand",
            "content": "<p>The build quality is industrial-grade. Durability is honestly unmatched.</p>"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "David Ross",
            "country": "australia",
            "content": "<p>The Caravan Kit is brilliant. No buckets, no mess, stores away perfectly.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
