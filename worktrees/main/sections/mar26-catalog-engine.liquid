  /* --- NAVIGATION --- */
  #mar26-catalog-{{ section.id }} .mar26-nav-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 12px; /* Slightly more gap */
    margin-top: 0px; /* Zero Margin */
    margin-bottom: 0px; /* Zero Bottom Margin */
    justify-content: flex-start; /* Aligned Left */
    border-bottom: none;
    padding-bottom: 5px; 
  }

  #mar26-catalog-{{ section.id }} .mar26-nav-link {
    padding: 8px 12px; /* Reduced sides (40% down from 20px is 12px) */
    border: none;
    border-radius: 8px; /* Industrial rounded-square */
    font-size: 12px; /* Standardized 12px */
    font-weight: 700;
    text-transform: none; 
    text-decoration: none;
    color: #ffffff; /* White text on blue */
    background-color: #2A3B56; /* Industrial Blue */
    transition: all 0.2s ease;
  }

  /* --- NAV WRAPPER --- */
  #mar26-catalog-{{ section.id }} .mar26-nav-wrapper {
    margin: 0;
    padding: 15px;
  }

  /* --- SEARCH PROMPT --- */
  #mar26-catalog-{{ section.id }} .mar26-nav-heading {
    font-size: 1.25rem;
    font-weight: 900;
    margin: 0 0 16px 0; /* Margin bottom added globally */
    padding: 0;
    color: #1E293B;
  }

  @media (max-width: 767px) {
    #mar26-catalog-{{ section.id }} {
      padding: 10px 10px 20px 10px !important; /* Tightened top container padding */
    }

    #mar26-catalog-{{ section.id }} .mar26-nav-wrapper {
      padding: 5px 0px !important; /* Tightened wrapper padding */
    }

    #mar26-catalog-{{ section.id }} .mar26-nav-bar {
      display: flex !important;
      flex-wrap: nowrap !important; /* Force single row for scroll */
      overflow-x: auto !important; /* Horizontal overflow scroll */
      -webkit-overflow-scrolling: touch !important; /* Inertial scroll on iOS */
      justify-content: flex-start !important; /* Left scroll start boundary */
      padding: 5px 10px 15px 10px !important; /* Extra bottom padding for hidden scrollbar area */
      scrollbar-width: none; /* Hide default scrollbar track Firefox */
    }

    #mar26-catalog-{{ section.id }} .mar26-nav-bar::-webkit-scrollbar {
      display: none !important; /* Hide scrollbar Webkit */
    }

    #mar26-catalog-{{ section.id }} .mar26-nav-link {
      flex: 0 0 auto !important; /* Keep width and prevent wrapping/shrink */
    }

    #mar26-catalog-{{ section.id }} .mar26-nav-heading {
      text-align: center; /* Center on mobile to match layout */
      font-size: 1.1rem;
      padding: 0; 
      margin-bottom: 12px !important; /* Mobile vertical gap */
    }
  }
</style>

<div class="mar26-catalog-container" id="mar26-catalog-{{ section.id }}">
  <!-- Navigation Header (Dynamic from Blocks) -->
  <div class="mar26-nav-wrapper">
    <h3 class="mar26-nav-heading">What are you looking for today?</h3>
    <nav class="mar26-nav-bar">
      {% for block in section.blocks %}
        {% if block.type == 'category_banner' %}
          <a href="#grid-{{ block.id }}" class="mar26-nav-link" data-scroll-to>
            {{- block.settings.title | default: "Category" -}}
          </a>
        {% endif %}
      {% endfor %}
    </nav>
  </div>

  {% paginate collection.products by 250 %}
    {% for block in section.blocks %}
      {% if block.type == 'category_banner' %}
        <div class="mar26-category-block" id="cat-{{ block.id }}" {{ block.shopify_attributes }}>
          <!-- Banner Section -->
          <div
            class="mar26-category-banner"
            style="
              background-color: {{ block.settings.bg_color }};
              color: {{ block.settings.text_color }};
            "
          >
            {% if block.settings.video != blank %}
              <div class="mar26-cat-banner-media">
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
              </div>
            {% elsif block.settings.image != blank %}
              <div class="mar26-cat-banner-media">
                {{ block.settings.image | image_url: width: 1000 | image_tag }}
              </div>
            {% endif %}

            <div class="mar26-cat-banner-text">
              {% if block.settings.pre_title != blank %}
                <div class="mar26-pre-title-wrap">
                  <div class="mar26-pre-title-line"></div>
                  <span class="mar26-pre-title-text">{{ block.settings.pre_title }}</span>
                </div>
              {% endif %}
              <h2 class="mar26-category-title">{{ block.settings.title }}</h2>
              <div class="mar26-category-desc">{{ block.settings.description }}</div>
            </div>
          </div>

          <div class="mar26-products-grid mar26-products-grid--catalogv" id="grid-{{ block.id }}">
            {% assign found_products = false %}
            {% assign products_to_render = block.settings.selected_products %}

            {% if products_to_render != blank %}
              {% for product in products_to_render %}
                {% render 'mar26-product-card-catalogv',
                  product: product
                %}
                {% assign found_products = true %}
              {% endfor %}
            {% endif %}

            {% if found_products == false %}
              <p style="grid-column: 1/-1; opacity: 0.5; font-style: italic;">
                No products found in this category.
              </p>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  {% endpaginate %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Smooth scrolling for navigation links
    document.querySelectorAll('[data-scroll-to]').forEach((anchor) => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const targetId = this.getAttribute('href');
        const targetElement = document.querySelector(targetId);

        if (targetElement) {
          targetElement.scrollIntoView({
            behavior: 'smooth',
            block: 'start',
          });
        }
      });
    });

    // Fallback rows logic for catalogv card layout
    const adjustCatalogvCard = (title) => {
      const group = title.closest('[data-catalogv-text-group]');
      if (!group) return;

      // Force inline styles reset to measure true scroll height
      title.style.webkitLineClamp = 'none';
      title.style.display = 'block';
      title.style.height = 'auto';

      const lh = parseFloat(window.getComputedStyle(title).lineHeight) || 20;
      const scrollHeight = title.scrollHeight;
      const lines = Math.round(scrollHeight / lh);

      // Clean inline styles to fall back to CSS declarations
      title.style.webkitLineClamp = '';
      title.style.display = '';
      title.style.height = '';

      if (lines >= 3) {
        group.classList.remove('has-2-lines');
        group.classList.add('has-3-lines');
      } else if (lines === 2) {
        group.classList.remove('has-3-lines');
        group.classList.add('has-2-lines');
      } else {
        group.classList.remove('has-2-lines', 'has-3-lines');
      }
    };

    const titles = document.querySelectorAll('[data-catalogv-title]');
    if (titles.length > 0 && typeof ResizeObserver !== 'undefined') {
      const observer = new ResizeObserver((entries) => {
        entries.forEach((entry) => {
          adjustCatalogvCard(entry.target);
        });
      });
      titles.forEach((title) => observer.observe(title));
    }
  });
</script>

{% schema %}
{
  "name": "MAR26 Catalog Engine",
  "settings": [],
  "blocks": [
    {
      "type": "category_banner",
      "name": "Category Banner",
      "settings": [
        {
          "type": "product_list",
          "id": "selected_products",
          "label": "Select Products for this Category",
          "info": "Explicitly select products for this category."
        },
        {
          "type": "text",
          "id": "pre_title",
          "label": "Pre-Title",
          "default": "SERIES"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#F8FBFF"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#1E293B"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MAR26 Catalog Engine"
    }
  ]
}
{% endschema %}
