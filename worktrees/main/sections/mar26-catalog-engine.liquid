  #mar26-catalog-{{ section.id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 30px 20px;
    font-family: 'Montserrat', sans-serif;
    overflow-x: hidden;
    scroll-behavior: smooth;
  }

  #mar26-catalog-{{ section.id }} .mar26-category-block {
    margin-bottom: 60px;
    scroll-margin-top: 80px; /* Offset for banner */
  }

  .mar26-products-grid {
    scroll-margin-top: 120px; /* DEEPER OFFSET: Lands on the first product */
  }

  /* --- BANNER STYLING --- */
  #mar26-catalog-{{ section.id }} .mar26-category-banner {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 15px; /* Added Top Margin */
    margin-bottom: 15px; /* Tightened from 32px */
    border: none !important;
    padding: 24px;
    margin-left: 0;
    margin-right: 0;
    border-radius: 15px;
    box-shadow: 0 15px 20px -15px rgba(0,0,0,0.2); /* Boosted Banner Shadow */
  }

  @media (min-width: 768px) {
    #mar26-catalog-{{ section.id }} .mar26-category-banner {
      flex-direction: row;
      align-items: center;
      border: none !important;
      border-radius: 20px; /* Banners get slightly more on desktop */
      padding: 30px 40px;
      gap: 40px;
    }
  }

  #mar26-catalog-{{ section.id }} .mar26-cat-banner-text {
    flex: 1;
    text-align: left;
    padding: 0 10px; /* Side margins for the text block */
  }

  #mar26-catalog-{{ section.id }} .mar26-pre-title-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px; /* Reduced */
  }

  #mar26-catalog-{{ section.id }} .mar26-pre-title-line {
    width: 24px;
    height: 3px;
    background-color: currentColor;
  }

  #mar26-catalog-{{ section.id }} .mar26-pre-title-text {
    font-size: 11px;
    font-weight: 900;
    text-transform: none;
    letter-spacing: 0.1em;
  }

  #mar26-catalog-{{ section.id }} .mar26-category-title {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem); /* Slightly smaller/tighter */
    font-weight: 900;
    text-transform: none;
    letter-spacing: -0.01em;
    margin: 0 0 8px 0; /* Tighter margin */
    line-height: 1.1;
  }

  #mar26-catalog-{{ section.id }} .mar26-products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); /* Calibrated: 300px */
    gap: 20px;
    align-items: stretch; /* Allow cards to stretch to the same height */
  }

  /* Catalogv specific layout: 2 columns on mobile, 3 on tablet, 4 on desktop */
  #mar26-catalog-{{ section.id }} .mar26-products-grid--catalogv {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    row-gap: 40px;
  }

  @media (min-width: 768px) {
    #mar26-catalog-{{ section.id }} .mar26-products-grid--catalogv {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      row-gap: 48px;
    }
  }

  @media (min-width: 1024px) {
    #mar26-catalog-{{ section.id }} .mar26-products-grid--catalogv {
      grid-template-columns: repeat(4, 1fr);
    }
  }

