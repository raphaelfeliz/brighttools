{% doc %}
  @prompt
    create a block named mar26-videos with 4 vertical videos.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-vertical-videos-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  padding: {{ block.settings.section_padding }}px 0;

  }

  .ai-vertical-videos__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.video_gap }}px;
    width: 100%;
  }

  .ai-vertical-videos__item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 14;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.placeholder_background }};
  }

  .ai-vertical-videos__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-vertical-videos__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_background }};
    position: relative;
  }

  .ai-vertical-videos__placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-vertical-videos__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: {{ block.settings.placeholder_text_color }};
    text-align: center;
    pointer-events: none;
    max-width: 90%;
  }

  @media screen and (max-width: 989px) {
    .ai-vertical-videos__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-vertical-videos__container-{{ ai_gen_id }} {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: minmax(65vw, 65vw);
      gap: {{ block.settings.video_gap | times: 0.7 }}px;
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-x: contain;
      scroll-snap-type: x mandatory;
      -ms-overflow-style: none;
      scrollbar-width: none;
      padding-bottom: 4px;
    }

    .ai-vertical-videos__container-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-vertical-videos__item-{{ ai_gen_id }} {
      height: 60vh;
      scroll-snap-align: start;
    }

    .ai-vertical-videos__video-{{ ai_gen_id }},
    .ai-vertical-videos__placeholder-{{ ai_gen_id }} {
      height: 100%;
    }
  }
{% endstyle %}

<vertical-videos-{{ ai_gen_id }}
  class="ai-vertical-videos-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-vertical-videos__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign video_key = 'video_' | append: i
        assign video = block.settings[video_key]
      %}
      
      <div class="ai-vertical-videos__item-{{ ai_gen_id }}">
        {% if video %}
          <video
            class="ai-vertical-videos__video-{{ ai_gen_id }}"
            playsinline
            {% if block.settings.autoplay %}autoplay{% endif %}
            {% if block.settings.loop %}loop{% endif %}
            {% if block.settings.muted %}muted{% endif %}
            {% if block.settings.controls %}controls{% endif %}
            preload="metadata"
          >
            {% for source in video.sources %}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {% endfor %}
          </video>
        {% else %}
          <div class="ai-vertical-videos__placeholder-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="23 7 16 12 23 17 23 7"></polygon>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
            </svg>
            <div class="ai-vertical-videos__empty-state-{{ ai_gen_id }}">
              Add video {{ i }}
            </div>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</vertical-videos-{{ ai_gen_id }}>

<script>
  (function() {
    class VerticalVideos{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('.ai-vertical-videos__video-{{ ai_gen_id }}');
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const video = entry.target;
            if (entry.isIntersecting) {
              if (video.paused && {{ block.settings.autoplay | json }}) {
                video.play().catch(() => {});
              }
            } else {
              if (!video.paused && {{ block.settings.pause_on_exit | json }}) {
                video.pause();
              }
            }
          });
        }, options);

        this.videos.forEach((video) => {
          observer.observe(video);
        });
      }
    }

    customElements.define('vertical-videos-{{ ai_gen_id }}', VerticalVideos{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "mar26-videos",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Videos"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "Video 1"
    },
    {
      "type": "video",
      "id": "video_2",
      "label": "Video 2"
    },
    {
      "type": "video",
      "id": "video_3",
      "label": "Video 3"
    },
    {
      "type": "video",
      "id": "video_4",
      "label": "Video 4"
    },
    {
      "type": "header",
      "content": "Video settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show controls",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "pause_on_exit",
      "label": "Pause when out of view",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "video_gap",
      "label": "Space between videos",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Vertical padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Video corner radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "placeholder_background",
      "label": "Placeholder background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "placeholder_text_color",
      "label": "Placeholder text",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "mar26-videos"
    }
  ]
}
{% endschema %}
