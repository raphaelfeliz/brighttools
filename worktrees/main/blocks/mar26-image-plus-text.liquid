{% doc %}
  @prompt
    Create a new theme section with a full-width background image and an overlapping semi-transparent dark text box on the left side containing: a bold heading, a paragraph description, and a styled outlined button with a link. The layout should be similar to a hero banner where the text box floats over the image. The section should be fully customizable via theme editor settings: image upload, heading text, description text, button label, and button link., remove border radius from the button. , add a small border radius to the button.
    remove border radius form the dark text box. and remove glassmorphism, make the box just semi transparent., make border radius slightly greater - not much. reduce the text box width by half.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .ai-hero-banner__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    z-index: 1;
  }

  .ai-hero-banner__picture-{{ ai_gen_id }},
  .ai-hero-banner__source-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-hero-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    max-height: 670px;
  object-fit: cover;
  object-position: bottom;
  object-position: 50% 70%;
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 550px;
  }

  .ai-hero-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-banner__content-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: 100%;
    max-width: {{ settings.page_width }}px;
    padding: 0 40px;
  }

  .ai-hero-banner__text-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.text_box_background }};
    padding: {{ block.settings.text_box_padding }}px;
    border-radius: 0;
    max-width: {{ block.settings.text_box_max_width }}px;
  }

  .ai-hero-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .ai-hero-banner__description-{{ ai_gen_id }} {
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    margin: 0 0 24px 0;
  }

  .ai-hero-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: transparent;
    color: {{ block.settings.button_text_color }};
    border: 2px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-hero-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      flex-direction: column;
      min-height: auto;
    }

    .ai-hero-banner__content-wrapper-{{ ai_gen_id }} {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      padding: 0;
    }

    .ai-hero-banner__text-box-{{ ai_gen_id }} {
      padding: 20px;
      max-width: 100%;
      background-color: #000000;
    }

    .ai-hero-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-hero-banner__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-hero-banner__button-{{ ai_gen_id }} {
      padding: 12px 24px;
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <picture class="ai-hero-banner__picture-{{ ai_gen_id }}">
        {% if block.settings.mobile_image %}
          <source
            media="(max-width: 749px)"
            srcset="
              {{ block.settings.mobile_image | image_url: width: 480 }} 480w,
              {{ block.settings.mobile_image | image_url: width: 750 }} 750w,
              {{ block.settings.mobile_image | image_url: width: 1100 }} 1100w
            "
            sizes="100vw"
            class="ai-hero-banner__source-{{ ai_gen_id }}"
          >
        {% endif %}

        <img
          src="{{ block.settings.background_image | image_url: width: 2000 }}"
          alt="{{ block.settings.background_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.background_image.width }}"
          height="{{ block.settings.background_image.height }}"
          class="ai-hero-banner__image-{{ ai_gen_id }}"
        >
      </picture>
    {% else %}
      <div class="ai-hero-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-banner__empty-state-{{ ai_gen_id }}">
          Add a background image to get started
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-banner__content-wrapper-{{ ai_gen_id }}">
    <div class="ai-hero-banner__text-box-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-hero-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-hero-banner__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}

      {% if block.settings.button_label != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-hero-banner__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Optional. Used on screens 749px and below."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our latest collection of premium products designed to elevate your everyday experience."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Text box style"
    },
    {
      "type": "range",
      "id": "text_box_max_width",
      "label": "Maximum width",
      "min": 150,
      "max": 400,
      "step": 25,
      "unit": "px",
      "default": 250
    },
    {
      "type": "range",
      "id": "text_box_padding",
      "label": "Padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "text_box_background",
      "label": "Background color",
      "default": "rgba(0,0,0,0.6)"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Size",
      "min": 12,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
